<%# #325 Phase 3a: Render-Vorschau des Topic-Work-Trees.
    #359 (Hans, 2026-05-25): Werks-Title + Subtitle (falls gesetzt)
    haben Vorrang vor dem Topic-Namen. %>
<%
  display_title    = @topic.work_tree_title.presence || @topic.name
  display_subtitle = @topic.work_tree_subtitle.presence
%>
<% content_for :title, display_title %>

<header class="mb-8 border-b border-slate-200 pb-4">
  <h1 class="text-2xl font-bold"><%= display_title %></h1>
  <% if display_subtitle %>
    <p class="text-base text-slate-600 italic mt-1"><%= display_subtitle %></p>
  <% end %>
  <% if @topic.description.present? %>
    <p class="text-slate-600 mt-2"><%= @topic.description %></p>
  <% end %>
  <p class="text-xs text-slate-400 mt-2">
    Vorschau-Render · <%= l(Time.current, format: :long) %> ·
    <%= link_to "← zurueck zum Topic", topic_path(@topic, tab: "work_tree"),
          class: "underline" %>
  </p>
</header>

<%= raw @rendered %>

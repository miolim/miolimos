<%# #556 (Hans, 2026-06-08): editierbarer bzw. gesperrter Felderbereich eines
    Anschreibens in EINEM Wrapper mit stabiler id. So kann ein Status-Wechsel
    (final↔entwurf) den ganzen Bereich per Turbo-Stream umschalten — ohne
    Browser-Refresh. Bei final read-only, sonst editierbar + Infoblock. %>
<% document = local_assigns.fetch(:document) %>
<div id="document_editor_<%= document.id %>">
  <% if document.locked? %>
    <%= render "documents/fields_readonly", document: document %>
  <% else %>
    <%= render "documents/fields", document: document %>
    <%# #559 (Hans): Reihenfolge Felder → Infoblock-Felder. %>
    <%= render "printables/infofields", printable: document %>
  <% end %>
</div>

<%# #926: Felder einer Rechnung / eines Angebots. #559: Label-Spalte links
    (Desktop) / oben (Mobil). Reihenfolge: Projekt, Status, Aussteller,
    Empfänger, Datum, [Betreff nur Angebot], Rechnungsnummer, Leistungszeitraum.
    Ihr/Unser Zeichen + Infoblock-Felder stehen in printables/_infofields. %>
<% rowcls = "grid grid-cols-1 sm:grid-cols-[8rem_1fr] sm:items-center gap-x-2 gap-y-0.5" %>
<% inputcls = "w-full border border-slate-200 rounded px-2 py-0.5 bg-white" %>
<div id="invoice_fields_<%= invoice.id %>" class="space-y-1.5 text-[13px]">
  <%# — Projekt — %>
  <div class="<%= rowcls %>">
    <span class="text-slate-500"><%= t("documents.fields.project") %></span>
    <%= render "shared/entity_picker",
          icon: "folder", icon_only: true, placeholder: t("documents.fields.topic_placeholder"), chips_first: true, close_after_pick: true,
          chips_id: "invoice_topic_chip_#{invoice.id}", chips_partial: "printables/link_chip",
          chips_locals: { printable: invoice, field: "topic", record: invoice.topic },
          suggest_url: suggest_links_invoices_path(kind: "topic"),
          add_url: link_invoice_path(invoice, field: "topic"),
          param_name: "value", create_label: "", allow_create: false %>
  </div>

  <%# — Status — %>
  <div class="<%= rowcls %>">
    <span class="text-slate-500"><%= t("documents.fields.status") %></span>
    <%= form_with url: invoice_path(invoice), method: :patch, local: false, class: "contents" do |f| %>
      <%= f.select :status, Invoice.statuses.keys.map { |s| [s.capitalize, s] }, { selected: invoice.status },
            onchange: "this.form.requestSubmit()", class: inputcls %>
    <% end %>
  </div>

  <%# — Aussteller — #946: Richtung im suggest_url — bei Eingangsrechnungen
      schlägt der Picker fremde Personen/Orgs vor statt der eigenen Firmen. %>
  <div class="<%= rowcls %>">
    <span class="text-slate-500"><%= t("documents.fields.issuer") %></span>
    <%= render "shared/entity_picker",
          icon: "building", icon_only: true, placeholder: t("documents.fields.issuer_placeholder"), chips_first: true, close_after_pick: true,
          chips_id: "invoice_issuer_chip_#{invoice.id}", chips_partial: "printables/link_chip",
          chips_locals: { printable: invoice, field: "issuer", record: invoice.issuer },
          suggest_url: suggest_links_invoices_path(kind: "issuer", direction: invoice.direction),
          add_url: link_invoice_path(invoice, field: "issuer"),
          param_name: "value", create_label: "", allow_create: false %>
  </div>

  <%# — Empfänger — %>
  <div class="<%= rowcls %>">
    <span class="text-slate-500"><%= t("documents.fields.recipient") %></span>
    <%= render "shared/entity_picker",
          icon: "users", icon_only: true, placeholder: t("documents.fields.recipient_placeholder"), chips_first: true, close_after_pick: true,
          chips_id: "invoice_recipient_chip_#{invoice.id}", chips_partial: "printables/link_chip",
          chips_locals: { printable: invoice, field: "recipient", record: invoice.recipient },
          suggest_url: suggest_links_invoices_path(kind: "recipient"),
          add_url: link_invoice_path(invoice, field: "recipient"),
          param_name: "value", create_label: "", allow_create: false %>
  </div>

  <%# #694 (Hans): Anschrift wählen, wenn der Empfänger MEHRERE Postadressen
      hat. Leer = automatisch (mailing_address). Bei 0/1 erscheint die Zeile nicht. %>
  <% recipient_addrs = invoice.recipient&.postal_addresses&.ordered.to_a %>
  <% if recipient_addrs.size > 1 %>
    <div class="<%= rowcls %>">
      <span class="text-slate-500"><%= t("documents.fields.address") %></span>
      <%= form_with url: invoice_path(invoice), method: :patch, local: false, class: "contents" do |f| %>
        <%= f.select :recipient_address_id,
              recipient_addrs.map { |a| [a.oneline, a.id] },
              { selected: invoice.chosen_recipient_address&.id,
                include_blank: t("documents.fields.address_auto", address: invoice.recipient.mailing_address&.oneline) },
              onchange: "this.form.requestSubmit()", class: inputcls %>
      <% end %>
    </div>
  <% end %>

  <%# — Datum — %>
  <div class="<%= rowcls %>">
    <span class="text-slate-500"><%= t("documents.fields.date") %></span>
    <%= form_with url: invoice_path(invoice), method: :patch, local: false, class: "contents" do |f| %>
      <%= f.date_field :document_date, value: invoice.document_date,
            onchange: "this.form.requestSubmit()", class: inputcls %>
    <% end %>
  </div>

  <%# — Betreff — #623 (Hans): nur Angebot (Rechnungen brauchen ihn nicht). %>
  <% if invoice.angebot? %>
    <div class="<%= rowcls %>">
      <span class="text-slate-500"><%= t("documents.fields.subject") %></span>
      <%= form_with url: invoice_path(invoice), method: :patch, local: false, class: "contents" do %>
        <%= text_field_tag :subject, invoice.subject,
              placeholder: t("documents.fields.subject_placeholder"),
              onblur: "if (this.value !== this.defaultValue) this.form.requestSubmit()",
              class: inputcls %>
      <% end %>
    </div>
  <% end %>

  <%# #541 — Rechnungsnummer + Leistungszeitraum (§14 UStG). %>
  <div class="<%= rowcls %>">
    <span class="text-slate-500"><%= t("documents.fields.invoice_number") %></span>
    <%= form_with url: invoice_path(invoice), method: :patch, local: false, class: "contents" do |f| %>
      <%= text_field_tag :number, invoice.number, placeholder: t("documents.fields.invoice_number_placeholder"),
            onblur: "if (this.value !== this.defaultValue) this.form.requestSubmit()", class: inputcls %>
    <% end %>
  </div>
  <div class="<%= rowcls %>">
    <span class="text-slate-500"><%= t("documents.fields.service_period") %></span>
    <div class="grid grid-cols-2 gap-2">
      <%= form_with url: invoice_path(invoice), method: :patch, local: false, class: "contents" do %>
        <%= date_field_tag :service_start, invoice.service_start, onchange: "this.form.requestSubmit()", class: inputcls %>
      <% end %>
      <%= form_with url: invoice_path(invoice), method: :patch, local: false, class: "contents" do %>
        <%= date_field_tag :service_end, invoice.service_end, onchange: "this.form.requestSubmit()", class: inputcls %>
      <% end %>
    </div>
  </div>

  <%# #934: Fälligkeit + Zahlstatus — nur bei Eingangsrechnungen. %>
  <% if invoice.eingehend? %>
    <div class="<%= rowcls %>">
      <span class="text-slate-500"><%= t("invoices.fields.due_date") %></span>
      <%= form_with url: invoice_path(invoice), method: :patch, local: false, class: "contents" do %>
        <%= date_field_tag :due_date, invoice.due_date, onchange: "this.form.requestSubmit()", class: inputcls %>
      <% end %>
    </div>
    <div class="<%= rowcls %>">
      <span class="text-slate-500"><%= t("invoices.fields.payment_status") %></span>
      <%= form_with url: invoice_path(invoice), method: :patch, local: false, class: "contents" do |f| %>
        <%= f.select :payment_status,
              Invoice.payment_statuses.keys.map { |s| [t("invoices.fields.payment_statuses.#{s}"), s] },
              { selected: invoice.payment_status },
              onchange: "this.form.requestSubmit()", class: inputcls %>
      <% end %>
    </div>
  <% end %>
</div>

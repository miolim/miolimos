<%# #625 (Hans): Überweisungs-Formular. Zwei Modi:
    A) ohne contact_uuid: Dropdown der Kontakte mit hinterlegter IBAN.
    B) mit contact_uuid (aus dem Personen-Blade): fixer Empfänger, IBAN
       editierbar und direkt am Kontakt hinterlegbar.
    Form + Ergebnis liegen in einem Turbo-Frame; jede Änderung lädt den
    Frame per GET neu und rendert den QR serverseitig (rqrcode). %>
<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="flex items-center gap-2 mb-1">
    <span class="text-emerald-600 [&_svg]:w-6 [&_svg]:h-6"><%= icon "banknote" %></span>
    <h1 class="text-lg font-semibold text-slate-800"><%= t("giro_codes.title") %></h1>
  </div>
  <p class="text-sm text-slate-500 mb-6">
    <%= t("giro_codes.intro") %>
  </p>

  <%= turbo_frame_tag "giro_tool" do %>
    <%= form_with url: giro_code_path, method: :get,
          data: { turbo_frame: "giro_tool" },
          class: "space-y-4 bg-white border border-slate-200 rounded-lg p-4" do |f| %>

      <% if @contact %>
        <%# Modus B: fixer Empfänger aus dem Personen-/Org-Blade. %>
        <%= f.hidden_field :contact_uuid, value: @contact_uuid %>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1"><%= t("giro_codes.recipient") %></label>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-slate-800"><%= @name %></span>
            <%= link_to t("giro_codes.choose_other"), giro_code_path,
                  data: { turbo_frame: "giro_tool" },
                  class: "text-[11px] text-slate-400 underline hover:no-underline" %>
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">IBAN</label>
          <%= f.text_field :iban, value: @iban,
                placeholder: t("giro_codes.iban_placeholder"),
                onchange: "this.form.requestSubmit()",
                class: "w-full rounded border border-slate-200 px-2 py-1.5 text-sm font-mono focus:outline-none focus:border-emerald-400" %>
          <% if @stored_iban.blank? %>
            <p class="text-[11px] text-amber-700 mt-1">
              <%= t("giro_codes.no_iban_stored", name: @name) %>
            </p>
          <% end %>
        </div>

      <% else %>
        <%# Modus A: Dropdown der Kontakte mit hinterlegter IBAN. %>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1"><%= t("giro_codes.recipient") %></label>
          <% if @contacts.any? %>
            <%= f.select :contact_uuid,
                  options_for_select(@contacts.map { |c| [c.title, c.uuid] }, @contact_uuid),
                  { include_blank: t("giro_codes.choose_contact") },
                  onchange: "this.form.requestSubmit()",
                  class: "w-full rounded border border-slate-200 bg-white px-2 py-1.5 text-sm focus:outline-none focus:border-emerald-400" %>
            <p class="text-[11px] text-slate-400 mt-1">
              <%= t("giro_codes.contacts_with_iban_hint") %>
            </p>
          <% else %>
            <p class="text-sm text-slate-500 border border-dashed border-slate-200 rounded px-3 py-4">
              <%= t("giro_codes.no_contacts_hint") %>
            </p>
          <% end %>
        </div>
      <% end %>

      <div class="flex gap-3">
        <div class="w-40">
          <label class="block text-xs font-medium text-slate-600 mb-1"><%= t("giro_codes.amount") %></label>
          <%= f.text_field :amount, value: @amount,
                inputmode: "decimal", placeholder: t("giro_codes.amount_placeholder"),
                onchange: "this.form.requestSubmit()",
                class: "w-full rounded border border-slate-200 px-2 py-1.5 text-sm tabular-nums focus:outline-none focus:border-emerald-400" %>
          <p class="text-[11px] text-slate-400 mt-1"><%= t("giro_codes.amount_hint") %></p>
        </div>
        <div class="flex-1">
          <label class="block text-xs font-medium text-slate-600 mb-1"><%= t("giro_codes.purpose") %></label>
          <%= f.text_field :purpose, value: @purpose,
                maxlength: 140, placeholder: t("giro_codes.purpose_placeholder"),
                onchange: "this.form.requestSubmit()",
                class: "w-full rounded border border-slate-200 px-2 py-1.5 text-sm focus:outline-none focus:border-emerald-400" %>
        </div>
      </div>
    <% end %>

    <%# IBAN am Kontakt hinterlegen (außerhalb des GET-Formulars — kein
        verschachteltes Form). Erscheint, sobald der getippte Wert noch
        nicht (so) gespeichert ist. %>
    <% if @can_save_iban %>
      <div class="mt-3">
        <%= button_to t("giro_codes.save_iban", name: @name), giro_code_save_iban_path,
              params: { contact_uuid: @contact_uuid, iban: @iban, bic: @bic,
                        amount: @amount, purpose: @purpose },
              data: { turbo_frame: "giro_tool" },
              class: "text-xs px-3 py-1.5 rounded border border-emerald-300 text-emerald-700 bg-emerald-50 hover:bg-emerald-100 cursor-pointer" %>
      </div>
    <% end %>

    <% if @giro_error.present? %>
      <div class="mt-4 text-sm text-amber-700 bg-amber-50 border border-amber-200 rounded px-3 py-2">
        <%= @giro_error %>
      </div>
    <% elsif @svg.present? %>
      <div class="mt-6 flex flex-col sm:flex-row gap-6 items-start bg-white border border-slate-200 rounded-lg p-4">
        <div class="shrink-0 w-44 h-44 [&_svg]:w-full [&_svg]:h-full">
          <%= raw @svg %>
        </div>
        <dl class="text-sm text-slate-700 space-y-1.5 min-w-0">
          <div><dt class="text-[11px] uppercase tracking-wide text-slate-400"><%= t("giro_codes.recipient") %></dt>
               <dd class="font-medium"><%= @name %></dd></div>
          <div><dt class="text-[11px] uppercase tracking-wide text-slate-400">IBAN</dt>
               <dd class="font-mono break-all"><%= @iban %></dd></div>
          <% if @bic.present? %>
            <div><dt class="text-[11px] uppercase tracking-wide text-slate-400">BIC</dt>
                 <dd class="font-mono"><%= @bic %></dd></div>
          <% end %>
          <% if @amount.present? %>
            <div><dt class="text-[11px] uppercase tracking-wide text-slate-400"><%= t("giro_codes.amount") %></dt>
                 <dd class="tabular-nums"><%= @amount %> €</dd></div>
          <% end %>
          <% if @purpose.present? %>
            <div><dt class="text-[11px] uppercase tracking-wide text-slate-400"><%= t("giro_codes.purpose") %></dt>
                 <dd><%= @purpose %></dd></div>
          <% end %>
          <p class="text-[11px] text-slate-400 pt-2">
            <%= t("giro_codes.scan_hint") %>
          </p>
        </dl>
      </div>
    <% end %>
  <% end %>
</div>

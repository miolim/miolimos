<%# #232 (Hans, 2026-06-01): Replies-Liste einer KI in einem turbo-frame.
    Wird inline von knowledge_items/_replies_section gerendert UND vom GET
    /knowledge_items/:uuid/replies (KnowledgeRepliesController#index)
    nachgeladen, wenn ein Reply-Live-Update broadcastet. Jede Session
    rendert mit ihrem eigenen current_actor (viewer-korrekt). Analog
    tasks/_replies_list. Locals: item (= Parent-KI) %>
<%
  replies   = KnowledgeItem.replies_for(item, viewer: current_actor)
  # #450 (Hans, 2026-06-01): Bei aktivem Highlight-Filter nur Antworten
  # mit passender Markierung zeigen — und in diesen nur die markierten
  # Stellen (highlight_filter an die Reply-Card durchreichen).
  active_hl = params[:hl].to_s.split(",").map(&:strip).reject(&:blank?)
  if active_hl.any?
    replies = replies.select { |r| (KnowledgeMarkdown.highlight_counts(r.body).keys & active_hl).any? }
  end
  last_two  = replies.last(2)
  older     = replies[0...-2] || []
%>
<turbo-frame id="knowledge_replies_list_frame_<%= item.uuid %>">
  <% if active_hl.any? %>
    <%# Filter-Modus: flache, aufgeklappte Liste aller passenden Antworten,
        jeweils nur die markierten Stellen. %>
    <% if replies.any? %>
      <ul id="knowledge_replies_list_<%= item.uuid %>" class="text-[13px]">
        <% replies.each do |reply| %>
          <%= render "shared/reply_card", reply: reply,
                update_url: knowledge_item_reply_path(item.uuid, reply.uuid),
                collapsed: false, highlight_filter: active_hl %>
        <% end %>
      </ul>
    <% else %>
      <p class="text-xs text-slate-400 italic py-1"><%= t("knowledge.list.replies.none_with_highlight") %></p>
    <% end %>
  <% elsif replies.any? %>
    <ul id="knowledge_replies_list_<%= item.uuid %>" class="text-[13px]">
      <% if older.any? %>
        <li data-controller="disclosure"
            data-disclosure-storage-key-value="ki.<%= item.uuid %>.replies.older"
            class="border-b border-slate-100">
          <button type="button"
                  data-action="click->disclosure#toggle"
                  class="w-full text-left flex items-center gap-2 py-2 px-1 text-xs text-slate-500 hover:bg-slate-50 rounded">
            <span data-disclosure-target="icon"
                  class="inline-block transition-transform text-slate-400">
              <%= icon "chevron_right" %>
            </span>
            <span><%= t("knowledge.list.replies.older", count: older.size) %></span>
          </button>
          <div data-disclosure-target="content" class="hidden pl-2">
            <ul class="text-[13px]">
              <% older.each do |reply| %>
                <%= render "shared/reply_card", reply: reply,
                      update_url: knowledge_item_reply_path(item.uuid, reply.uuid),
                      collapsed: true %>
              <% end %>
            </ul>
          </div>
        </li>
      <% end %>

      <% last_two.each_with_index do |reply, idx| %>
        <%= render "shared/reply_card", reply: reply,
              update_url: knowledge_item_reply_path(item.uuid, reply.uuid),
              collapsed: idx < last_two.size - 1 %>
      <% end %>
    </ul>
  <% end %>
</turbo-frame>

<% content_for :title, @template.name %>

<div class="max-w-3xl mx-auto space-y-3">
  <header class="flex items-baseline gap-2">
    <%= link_to "← Vorlagen", prompt_templates_path,
          class: "text-xs text-slate-500 hover:text-slate-900" %>
    <span class="ml-auto flex items-center gap-2 text-xs">
      <%= link_to t("actions.edit"), edit_prompt_template_path(@template.slug),
            class: "px-2 py-1 rounded border border-slate-200 hover:bg-slate-50" %>
      <%= button_to t("actions.delete"), prompt_template_path(@template.slug), method: :delete,
            class: "px-2 py-1 rounded text-rose-700 hover:bg-rose-50",
            form: { class: "inline", data: { turbo_confirm: t("prompt_templates.delete_confirm") } } %>
    </span>
  </header>

  <section class="bg-white rounded border border-slate-200 p-4 space-y-2">
    <h1 class="text-xl font-semibold"><%= @template.name %></h1>
    <p class="text-xs font-mono text-slate-500">@<%= @template.slug %></p>
    <% if @template.default_model.present? %>
      <p class="text-xs text-slate-600">Modell: <span class="font-mono"><%= @template.default_model %></span></p>
    <% end %>
    <% if @template.description.present? %>
      <p class="text-sm text-slate-700"><%= @template.description %></p>
    <% end %>
    <pre class="bg-slate-50 rounded border border-slate-200 px-3 py-2 text-xs font-mono whitespace-pre-wrap mt-2"><%= @template.prompt_text %></pre>
  </section>
</div>

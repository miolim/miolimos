<%# #546 (Hans): Beziehungen (Person↔Person / Org↔Org), Outgoing-Seite.
    Chevron + getrennte Anzeige/Edit + Add/Edit in der Titelzeile + Lösch-
    Rückfrage. Speichert via PATCH ans KI. Eingehende read-only via Mirrors. %>
<% rels = item.outgoing_relationships.includes(:to_person).ordered %>
<%# #681 (Hans): leere Sektion standardmäßig eingeklappt. %>
<% collapsed = rels.empty? %>
<% row = "grid grid-cols-[1fr_1fr_5rem_5rem_auto] gap-1 px-3 py-1.5 items-center text-[13px] border-b border-slate-50" %>
<section data-controller="disclosure section-edit rows-editor"
         data-disclosure-storage-key-value="knowledge.<%= item.uuid %>.relations_edit"
         class="border border-slate-200 rounded">
  <header class="px-3 py-1.5 text-xs text-slate-600 border-b border-slate-100 font-medium flex items-center gap-2 bg-slate-50 rounded-t">
    <button type="button" data-action="click->disclosure#toggle"
            class="flex items-center gap-2 flex-1 text-left bg-transparent border-0 p-0 cursor-pointer text-slate-600">
      <span data-disclosure-target="icon" class="inline-block transition-transform <%= 'rotate-90' unless collapsed %> text-slate-400 [&_svg]:w-3.5 [&_svg]:h-3.5"><%= icon "chevron_right" %></span>
      <span><%= t("knowledge.editors.relationships.title") %> · <%= rels.size %></span>
    </button>
    <button type="button" data-action="click->section-edit#edit" title="<%= t("actions.edit") %>"
            class="p-0.5 text-slate-400 hover:text-slate-700 [&_svg]:w-3.5 [&_svg]:h-3.5"><%= icon "pencil" %></button>
    <button type="button" data-action="click->section-edit#edit click->rows-editor#add"
            title="<%= t("knowledge.editors.relationships.add") %>" class="p-0.5 text-emerald-600 hover:text-emerald-800 [&_svg]:w-4 [&_svg]:h-4"><%= icon "plus_circle" %></button>
  </header>

  <div data-disclosure-target="content" class="<%= 'hidden' if collapsed %>">
    <%# ── Anzeige ── %>
    <div data-section-edit-target="display" class="px-3 py-2 text-[13px] space-y-1">
      <% if rels.any? %>
        <% rels.each do |r| %>
          <div><span class="text-slate-500"><%= r.kind %>:</span> <%= r.to_person.title %><% if r.start_at || r.end_at %> <span class="text-slate-400 text-xs"><%= r.start_at&.year %><%= "–#{r.end_at&.year}" if r.end_at %></span><% end %></div>
        <% end %>
      <% else %>
        <p class="text-slate-400 italic"><%= t("knowledge.editors.relationships.empty") %></p>
      <% end %>
    </div>

    <%# ── Edit ── %>
    <div data-section-edit-target="edit" hidden>
      <%= form_with url: knowledge_item_path(item.uuid), method: :patch, local: false do |f| %>
        <% if in_stack %><%= f.hidden_field :in_stack, value: "1" %><% end %>
        <template data-rows-editor-target="template">
          <div data-row class="<%= row %>">
            <input type="text" name="relationships[][to]" placeholder="<%= t("knowledge.editors.relationships.target_placeholder") %>" list="rel-suggestions-<%= item.uuid %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
            <input type="text" name="relationships[][kind]" placeholder="<%= t("knowledge.editors.relationships.kind_placeholder") %>" list="rel-kind-suggestions" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
            <input type="date" name="relationships[][from]" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
            <input type="date" name="relationships[][to_at]" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
            <button type="button" data-action="click->rows-editor#removeConfirm" class="p-1 text-slate-400 hover:text-rose-600">×</button>
          </div>
        </template>

        <div data-rows-editor-target="rows">
          <% rels.each do |r| %>
            <div data-row data-existing="true" class="<%= row %>">
              <input type="text" name="relationships[][to]" value="<%= r.to_person.title %>" list="rel-suggestions-<%= item.uuid %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
              <input type="text" name="relationships[][kind]" value="<%= r.kind %>" list="rel-kind-suggestions" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
              <input type="date" name="relationships[][from]" value="<%= r.start_at %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
              <input type="date" name="relationships[][to_at]" value="<%= r.end_at %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
              <button type="button" data-action="click->rows-editor#removeConfirm" class="p-1 text-slate-400 hover:text-rose-600">×</button>
            </div>
          <% end %>
        </div>

        <datalist id="rel-suggestions-<%= item.uuid %>">
          <% KnowledgeItem.where(item_type: [:person, :organization]).order(:title).pluck(:title).each do |t| %><option value="<%= t %>"></option><% end %>
        </datalist>
        <datalist id="rel-kind-suggestions">
          <% kinds_default = ["Ehepartner:in","Kind","Elternteil","Geschwister","Kolleg:in","Mentor:in","Mentee","Freund:in","bekannt von","Co-Autor:in","Sparringspartner:in","Tochter-Org von","Mutter-Org von"] %>
          <% (kinds_default + (Relationship.distinct.pluck(:kind).compact - kinds_default)).each do |k| %><option value="<%= k %>"></option><% end %>
        </datalist>

        <div class="flex items-center gap-2 px-3 py-2 border-t border-slate-100 bg-slate-50/50">
          <button type="button" data-action="click->section-edit#cancel" class="text-xs px-2 py-0.5 rounded text-slate-600 hover:bg-slate-100"><%= t("actions.cancel") %></button>
          <button type="submit" class="ml-auto text-xs px-3 py-0.5 rounded bg-emerald-600 text-white hover:bg-emerald-700 cursor-pointer"><%= t("actions.save") %></button>
        </div>
      <% end %>
    </div>
  </div>
</section>

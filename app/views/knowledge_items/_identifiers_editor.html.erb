<%# #544/#546 (Hans): ID-Nummern eines Person/Org-KI. Section mit Chevron
    (disclosure), getrennter Anzeige/Edit-Ansicht (section-edit), Hinzufügen +
    Bearbeiten in der Titelzeile, Löschung mit Rückfrage. DB ist Source of
    Truth — Save schreibt direkt in die identifiers-Tabelle. Locals: item, in_stack %>
<% return unless item.item_type.in?(%w[person organization]) %>
<% ids = item.identifiers.includes(:counterparty).ordered %>
<% incoming = item.identifiers_as_counterparty.includes(:knowledge_item).order(:position, :id) %>
<%# #681 (Hans): leere Sektion standardmäßig eingeklappt. %>
<% collapsed = ids.empty? && incoming.empty? %>
<section id="identifiers_section_<%= item.uuid %>"
         data-controller="disclosure section-edit rows-editor"
         data-disclosure-storage-key-value="knowledge.<%= item.uuid %>.ids"
         class="border border-slate-200 rounded">
  <header class="px-3 py-1.5 text-xs text-slate-600 border-b border-slate-100 font-medium flex items-center gap-2 bg-slate-50 rounded-t">
    <button type="button" data-action="click->disclosure#toggle"
            class="flex items-center gap-2 flex-1 text-left bg-transparent border-0 p-0 cursor-pointer text-slate-600">
      <span data-disclosure-target="icon" class="inline-block transition-transform <%= 'rotate-90' unless collapsed %> text-slate-400 [&_svg]:w-3.5 [&_svg]:h-3.5"><%= icon "chevron_right" %></span>
      <span><%= t("knowledge.editors.identifiers.title") %> · <%= ids.size %></span>
    </button>
    <button type="button" data-action="click->disclosure#expand click->section-edit#edit" title="<%= t("actions.edit") %>"
            class="p-0.5 text-slate-400 hover:text-slate-700 [&_svg]:w-3.5 [&_svg]:h-3.5"><%= icon "pencil" %></button>
    <button type="button" data-action="click->disclosure#expand click->section-edit#edit click->rows-editor#add"
            title="<%= t("knowledge.editors.identifiers.add") %>" class="p-0.5 text-emerald-600 hover:text-emerald-800 [&_svg]:w-4 [&_svg]:h-4"><%= icon "plus_circle" %></button>
  </header>

  <div data-disclosure-target="content" class="<%= 'hidden' if collapsed %>">
    <%# ── Anzeige (read-only) ── %>
    <div data-section-edit-target="display" class="px-3 py-2 text-[13px] space-y-1">
      <% if ids.any? %>
        <% ids.each do |idr| %>
          <%# #723 (Hans): Kopier-Icon für die ID-Nummer. %>
          <div class="flex items-center gap-1.5">
            <span class="min-w-0 break-all"><span class="text-slate-500"><%= idr.label %>:</span> <span class="font-mono"><%= idr.value %></span><% if idr.counterparty %> <span class="text-slate-400">· <%= idr.counterparty.title %></span><% end %></span>
            <% if idr.value.present? %>
              <button type="button" data-controller="copy-clipboard" data-action="click->copy-clipboard#copy"
                      data-copy-clipboard-content-value="<%= idr.value %>" data-copy-clipboard-toast-value="<%= t("knowledge.editors.identifiers.copied", label: idr.label) %>"
                      title="<%= t("knowledge.editors.identifiers.copy", label: idr.label) %>" aria-label="<%= t("knowledge.editors.identifiers.copy", label: idr.label) %>"
                      class="shrink-0 p-0.5 rounded text-slate-400 hover:text-slate-700 hover:bg-slate-100 cursor-pointer [&_svg]:w-3.5 [&_svg]:h-3.5"><%= icon "copy" %></button>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <p class="text-slate-400 italic"><%= t("knowledge.editors.identifiers.empty") %></p>
      <% end %>
      <% if incoming.any? %>
        <div class="pt-1 mt-1 border-t border-slate-100 text-[12px] text-slate-500">
          <div class="text-slate-400 mb-0.5"><%= t("knowledge.editors.identifiers.assigned_to_others") %></div>
          <% incoming.each do |idr| %>
            <div class="flex items-center gap-1.5">
              <span class="min-w-0 break-all"><%= idr.label %> <span class="font-mono"><%= idr.value %></span> · <%= idr.knowledge_item&.title %></span>
              <% if idr.value.present? %>
                <button type="button" data-controller="copy-clipboard" data-action="click->copy-clipboard#copy"
                        data-copy-clipboard-content-value="<%= idr.value %>" data-copy-clipboard-toast-value="<%= t("knowledge.editors.identifiers.copied", label: idr.label) %>"
                        title="<%= t("knowledge.editors.identifiers.copy", label: idr.label) %>" aria-label="<%= t("knowledge.editors.identifiers.copy", label: idr.label) %>"
                        class="shrink-0 p-0.5 rounded text-slate-400 hover:text-slate-700 hover:bg-slate-100 cursor-pointer [&_svg]:w-3.5 [&_svg]:h-3.5"><%= icon "copy" %></button>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# ── Edit ── %>
    <div data-section-edit-target="edit" hidden>
      <%= form_with url: identifiers_knowledge_item_path(item.uuid), method: :patch, local: false do |f| %>
        <% if in_stack %><%= f.hidden_field :in_stack, value: "1" %><% end %>
        <template data-rows-editor-target="template">
          <div data-row class="grid grid-cols-[1fr_1fr_1fr_auto] gap-1 px-3 py-1.5 items-center text-[13px] border-b border-slate-50">
            <input type="text" name="identifiers[][label]" placeholder="<%= t("knowledge.editors.identifiers.type_placeholder") %>" list="id-type-suggestions" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
            <input type="text" name="identifiers[][value]" placeholder="<%= t("knowledge.editors.identifiers.number_placeholder") %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
            <input type="text" name="identifiers[][counterparty]" placeholder="<%= t("knowledge.editors.identifiers.counterparty_placeholder") %>" list="id-counterparty-suggestions-<%= item.uuid %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
            <button type="button" data-action="click->rows-editor#removeConfirm" class="p-1 text-slate-400 hover:text-rose-600">×</button>
          </div>
        </template>

        <div data-rows-editor-target="rows">
          <% ids.each do |idr| %>
            <div data-row class="grid grid-cols-[1fr_1fr_1fr_auto] gap-1 px-3 py-1.5 items-center text-[13px] border-b border-slate-50">
              <input type="hidden" name="identifiers[][id]" value="<%= idr.id %>">
              <input type="text" name="identifiers[][label]" value="<%= idr.label %>" placeholder="<%= t("knowledge.editors.identifiers.type_short_placeholder") %>" list="id-type-suggestions" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
              <input type="text" name="identifiers[][value]" value="<%= idr.value %>" placeholder="<%= t("knowledge.editors.identifiers.number_placeholder") %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
              <input type="text" name="identifiers[][counterparty]" value="<%= idr.counterparty&.title %>" placeholder="<%= t("knowledge.editors.identifiers.counterparty_placeholder") %>" list="id-counterparty-suggestions-<%= item.uuid %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
              <button type="button" data-action="click->rows-editor#removeConfirm" class="p-1 text-slate-400 hover:text-rose-600">×</button>
            </div>
          <% end %>
        </div>

        <datalist id="id-type-suggestions">
          <% ["USt-IdNr", "Steuernummer", "Steuer-IdNr", "Gläubiger-Identifikationsnummer", "Kundennummer", "Vertragsnummer", "Versichertennummer", "Mitgliedsnummer", "Personalnummer", "ORCID", "IBAN"].each do |t| %><option value="<%= t %>"></option><% end %>
        </datalist>
        <datalist id="id-counterparty-suggestions-<%= item.uuid %>">
          <% KnowledgeItem.persons_and_orgs.order(Arel.sql("LOWER(title)")).limit(500).pluck(:title).each do |t| %><% next if t == item.title %><option value="<%= t %>"></option><% end %>
        </datalist>

        <div class="flex items-center gap-2 px-3 py-2 border-t border-slate-100 bg-slate-50/50">
          <button type="button" data-action="click->section-edit#cancel" class="text-xs px-2 py-0.5 rounded text-slate-600 hover:bg-slate-100"><%= t("actions.cancel") %></button>
          <button type="submit" class="ml-auto text-xs px-3 py-0.5 rounded bg-emerald-600 text-white hover:bg-emerald-700 cursor-pointer"><%= t("actions.save") %></button>
        </div>
      <% end %>
    </div>
  </div>
</section>

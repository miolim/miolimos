<%# #435 (Hans, 2026-06-01): Listen-Blade ueber ALLE Topics. Eigener
    Nav-Eintrag in der Sidebar (Icon "folder"), Klick auf ein Topic haengt
    dessen Listen-Blade an den Stack (kind topic_list — wie das Sidebar-
    Plus). Self-contained Fallback fuer den BladeStackLoader-Pfad.
    Locals: topics (Array<Topic>, optional). %>
<%
  topics = local_assigns[:topics]
  topics = Topic.non_templates.active.top_level.order(:name).to_a if topics.nil?
  total  = topics.size
%>
<article id="stack_card_list:topics"
         data-uuid="list:topics"
         class="stack-card shrink-0 relative
                w-[24rem] max-w-[calc(100vw-3rem)]
                bg-white border-l border-slate-200 first:border-l-0
                flex">

  <aside class="stack-spine self-stretch w-7 shrink-0
                bg-slate-50 border-r border-slate-200
                flex flex-col items-center pt-2 gap-2
                cursor-pointer hover:bg-slate-100"
         title="<%= t("nav.topics") %>"
         data-action="click->blade-stack#focusCard dblclick->blade-stack#toggleCollapse"
         data-target-uuid="list:topics">
    <span class="shrink-0 text-slate-500"><%= icon "folder", size: "w-5 h-5" %></span>
    <span class="text-xs text-slate-700 font-medium whitespace-nowrap overflow-hidden text-ellipsis
                 [writing-mode:vertical-rl] min-h-0 flex-1">
      <%= t("nav.topics") %>
    </span>
    <%= render "shared/blade_close_button" %>
  </aside>

  <div class="flex-1 min-w-0 min-h-0 overflow-y-auto p-3 space-y-3"
       data-controller="list-search"
       data-list-search-selector-value="li[data-topic]">
    <%# #455 (Hans, 2026-06-02): popover-fixed-value=true — sonst wird das
        Popover (Neues-Thema-Form) vom overflow-y-auto der Blade-Card
        abgeschnitten und der Plus-Klick schien wirkungslos. position:fixed
        legt den Inhalt an den Trigger, ausserhalb des Clip-Containers
        (gleiche Konvention wie knowledge_items/_type_picker). %>
    <%# #703 (Hans): einheitlicher Topbereich (kein extra Kasten). Add =
        „Neues Thema"-Popover (position:fixed gegen Card-Clipping). %>
    <% add_topic = capture do %>
      <div class="relative" data-controller="popover" data-popover-fixed-value="true">
        <button type="button" data-action="click->popover#toggle"
                title="<%= t("topics.new_topic") %>" aria-label="<%= t("topics.new_topic") %>"
                class="shrink-0 p-0.5 rounded text-slate-400 hover:text-slate-900 hover:bg-slate-100 cursor-pointer">
          <%= icon "plus_circle", size: "w-4 h-4" %>
        </button>
        <div data-popover-target="content"
             class="hidden absolute top-full right-0 z-30 mt-1 w-56 bg-white border border-slate-200 rounded shadow-xl p-2">
          <%= form_with url: topics_path, method: :post, local: true, class: "space-y-1.5" do |f| %>
            <%= text_field_tag "topic[name]", nil, placeholder: t("topics.name_placeholder"),
                  required: true, autofocus: true,
                  class: "w-full text-xs px-2 py-1 rounded border border-slate-300 focus:outline-none focus:border-emerald-400" %>
            <div class="flex items-center gap-2">
              <%= color_field_tag "topic[color]", "#94a3b8",
                    class: "h-6 w-8 rounded border border-slate-300 cursor-pointer" %>
              <%= submit_tag "Anlegen",
                    class: "flex-1 text-xs px-2 py-1 rounded bg-emerald-600 text-white hover:bg-emerald-700 cursor-pointer" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
    <%= render "shared/list_header",
          lead_icon: "folder", title: t("nav.topics"), count: total,
          add: add_topic,
          search: (total > 0 ? render("shared/list_search", placeholder: t("topics.list_search_placeholder")) : nil) %>

    <% if total.zero? %>
      <p class="text-sm text-slate-400 italic"><%= t("topics.no_topics") %></p>
    <% end %>
    <p data-list-search-target="empty" class="hidden text-xs text-slate-400 italic"><%= t("topics.no_results") %></p>

    <%# #464 (Hans, 2026-06-02): Sub-Topics hierarchisch (rekursive Zeile),
        analog zur Sidebar. `topics` sind die Top-Level-Themen; die Zeile
        holt ihre Sub-Topics selbst. %>
    <ul class="space-y-0.5">
      <% topics.each do |topic| %>
        <%= render "topics/blade_topic_row", topic: topic %>
      <% end %>
    </ul>
  </div>
</article>

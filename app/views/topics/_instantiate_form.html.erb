<div class="mt-3 pt-3 border-t border-slate-100">
  <%= form_with url: instantiate_topic_path(topic), method: :post, local: true, class: "flex gap-2 items-end flex-wrap" do |f| %>
    <div class="flex-1 min-w-64">
      <label class="block text-xs text-slate-600 mb-1"><%= t("topics.new_name") %></label>
      <%= f.text_field :new_name, required: true,
            class: "w-full rounded border border-slate-200 px-2 py-1 text-sm" %>
    </div>
    <%= f.submit t("topics.instantiate"),
          class: "text-xs px-3 py-1.5 rounded bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer" %>
  <% end %>
</div>

<%# #163 Phase 5a-2: Listen-Blade fuer Kommunikation. %>
<%
  stack_id = "list:communications"
  comms    = Communication.order(sent_at: :desc).limit(50).to_a
%>
<article id="stack_card_<%= stack_id %>"
         data-uuid="<%= stack_id %>"
         class="stack-card shrink-0 relative w-[26rem] max-w-[calc(100vw-3rem)]
                bg-white border-l border-slate-200 first:border-l-0 flex">

  <aside class="stack-spine self-stretch w-7 shrink-0 bg-slate-50 border-r border-slate-200
                flex flex-col items-center pt-2 gap-2 cursor-pointer hover:bg-slate-100"
         title="<%= t("communications.list_title") %>"
         data-action="click->blade-stack#focusCard dblclick->blade-stack#toggleCollapse"
         data-target-uuid="<%= stack_id %>">
    <span class="shrink-0 text-slate-500"><%= icon "communications" %></span>
    <span class="text-xs text-slate-700 font-medium whitespace-nowrap overflow-hidden text-ellipsis
                 [writing-mode:vertical-rl] min-h-0 flex-1">
      <%= t("communications.list_title") %>
    </span>
    <%= render "shared/blade_close_button" %>
  </aside>

  <div class="flex-1 min-w-0 min-h-0 overflow-y-auto p-3 space-y-2"
       data-controller="list-search">
    <%# #703 (Hans): einheitlicher Topbereich via shared/list_header. %>
    <%= render "shared/list_header",
          lead_icon: "communications", title: t("communications.list_title"),
          count: comms.size, total: Communication.count,
          search: render("shared/list_search", placeholder: t("communications.list_search_placeholder")) %>

    <% if comms.empty? %>
      <p class="text-sm text-slate-400 italic py-3"><%= t("communications.none") %></p>
    <% else %>
      <ul class="divide-y divide-slate-100 text-[13px]">
        <% comms.each do |c| %>
          <li class="py-1.5 hover:bg-slate-50 flex items-baseline gap-2">
            <span class="shrink-0 <%= c.inbound? ? 'text-blue-600' : 'text-slate-400' %>"><%= c.inbound? ? '↓' : '↑' %></span>
            <%# #163 Phase 5b-1: Communication als Detail-Blade appenden. %>
            <a href="#"
               data-action="click->blade-stack#openCommunication"
               data-communication-id="<%= c.id %>"
               class="flex-1 min-w-0 hover:underline text-slate-700">
              <span class="truncate inline-block max-w-full align-bottom"><%= c.subject.presence || t("communications.no_subject") %></span>
            </a>
            <% if c.sent_at %>
              <span class="text-xs text-slate-500 shrink-0 tabular-nums"><%= l(c.sent_at, format: :short) %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
      <p data-list-search-target="empty" class="hidden text-xs text-slate-400 italic py-2"><%= t("communications.no_results") %></p>
    <% end %>
  </div>
</article>

<%# #418 (Hans, 2026-05-30): Listen-Blade fuer einen Tag.
    Zeigt alle Tasks + KIs, die diesen Tag tragen.
    Locals:
      - tag                (String — Tag-Name)
      - tasks              (Array<Task>, optional)
      - knowledge_items    (Array<KnowledgeItem>, optional)
%>
<%
  # #419 (Hans, 2026-05-30): wenn das Partial direkt aus dem
  # BladeStackLoader (Initial-Stack-Render) gerendert wird, kommen
  # nur `tag` (der Name) — Tasks/KIs holen wir dann hier selbst.
  tag = local_assigns[:tag] || ""
  if local_assigns[:tasks].nil? && local_assigns[:knowledge_items].nil?
    tasks_arr = Task.open.without_template_tasks
                    .where("tasks.tags && ARRAY[?]::varchar[]", [tag])
                    .includes(:topics, :assignee)
                    .order(created_at: :desc)
                    .to_a
    direct_uuids = KnowledgeItem
                    .where("knowledge_items.tags && ARRAY[?]::varchar[]", [tag])
                    .pluck(:uuid)
    anchor_uuids = KnowledgeItemAnchor
                    .where("tags && ARRAY[?]::varchar[]", [tag])
                    .pluck(:knowledge_item_uuid)
    ki_uuids     = (direct_uuids + anchor_uuids).uniq
    kis_arr      = KnowledgeItem.where(uuid: ki_uuids).order(updated_at: :desc).to_a
  else
    tasks_arr = local_assigns[:tasks] || []
    kis_arr   = local_assigns[:knowledge_items] || []
  end
  total = tasks_arr.size + kis_arr.size
%>
<article id="stack_card_<%= "list:tag:#{tag}" %>"
         data-uuid="list:tag:<%= tag %>"
         class="stack-card shrink-0 relative
                w-[28rem] max-w-[calc(100vw-3rem)]
                bg-white border-l border-slate-200 first:border-l-0
                flex">

  <%= render "shared/list_blade_spine",
        title: t("tags.tag_label", tag: tag),
        icon_html: (tag_icon_html(tag, size: "w-5 h-5") || icon("filter", size: "w-5 h-5")),
        stack_id: "list:tag:#{tag}",
        label: t("tags.tag_label", tag: tag) %>

  <div class="flex-1 min-w-0 min-h-0 overflow-y-auto p-4 space-y-3">
    <%# #1049: Card-Werkzeugleiste wie bei Detail-Cards — p-4-Body, daher
        4er-Negativ-Margins. %>
    <%= render "shared/list_blade_toolbar", stack_id: "list:tag:#{tag}",
          toolbar_class: "-mx-4 -mt-4 mb-4 px-4 pt-2 pb-2 bg-white" %>
    <header class="flex items-center gap-2 -mt-1 mb-2">
      <% if (ic = tag_icon_html(tag, size: "w-4 h-4")) %>
        <span class="text-slate-500 inline-flex items-center"><%= ic %></span>
      <% end %>
      <h1 class="text-lg font-semibold flex-1 truncate">
        <%= t("tags.tag_label", tag: tag) %>
      </h1>
      <span class="text-xs text-slate-500"><%= total %></span>
      <%# #1049: Dashboard-Anhängen (#1005) sitzt jetzt in der Card-Werkzeugleiste. %>
    </header>

    <% if tasks_arr.any? %>
      <section>
        <h2 class="text-xs font-medium uppercase tracking-wider text-slate-500 mb-1">
          <%= t("tags.tasks_heading", count: tasks_arr.size) %>
        </h2>
        <ul class="space-y-1">
          <% tasks_arr.each do |task| %>
            <li>
              <%= render "tasks/row", task: task, topic: task.topics.first, blade_kind: "task", blade_id: task.id %>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <% if kis_arr.any? %>
      <section>
        <h2 class="text-xs font-medium uppercase tracking-wider text-slate-500 mb-1">
          <%= t("tags.knowledge_heading", count: kis_arr.size) %>
        </h2>
        <ul class="space-y-1">
          <% kis_arr.each do |ki| %>
            <li>
              <%= render "knowledge_items/list_row", item: ki %>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <% if total.zero? %>
      <p class="text-sm text-slate-400 italic">
        <%= t("tags.no_items") %>
      </p>
    <% end %>
  </div>
</article>

<%# #163 Phase 5b + #217: Communication-Blade nutzt jetzt den vollen
    detail_body (statt Glance), damit Topics direkt im Stack
    bearbeitet werden koennen. %>
<% stack_id = "communication:#{communication.id}" %>
<article id="stack_card_<%= stack_id %>"
         data-uuid="<%= stack_id %>"
         class="stack-card shrink-0 relative
                w-[36rem] max-w-[calc(100vw-3rem)]
                bg-white border-l border-slate-200 first:border-l-0
                flex">

  <%= render "shared/blade_spine", stack_id: stack_id,
        title: (communication.subject.presence || "(ohne Betreff)"),
        icon_class: communication.inbound? ? "text-blue-600" : "text-slate-400",
        icon_html: (communication.inbound? ? "↓" : "↑"),
        label: (communication.subject.presence || "(ohne Betreff)"),
        topics: communication.topics %>

  <div class="flex-1 min-w-0 min-h-0 overflow-y-auto p-4">
    <%# #868: Card-Werkzeugleiste über das gemeinsame Partial (nur Schließen;
        sticky-Container wie zuvor). %>
    <%= render "shared/blade_toolbar", uuid: stack_id,
          toolbar_class: "sticky -top-4 -mx-4 -mt-4 px-4 pt-2 pb-2 bg-white/95 backdrop-blur z-20",
          duplicate: false, reload: false, focus: false %>

    <div class="mt-3">
      <%= render "communications/detail_body", comm: communication %>
    </div>
  </div>
</article>

# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore key files for decrypting credentials and more.
/config/*.key
# #735: das echte Produktions-Credentials-Blob bleibt lokal — im (künftig
# öffentlichen) Repo hat auch der Ciphertext echter Keys nichts verloren.
# Selbst-Hoster erzeugen ihr eigenes (siehe README Quick start).
/config/credentials.yml.enc


# SimpleCov output
/coverage/

/app/assets/builds/*
!/app/assets/builds/.keep

# Tailwind build artifacts
/app/assets/builds/*
!/app/assets/builds/.keep

# Bundled gems (Deploy-Artefakt)
/vendor/bundle/
.playwright-mcp/

# Claude Code local state (cron locks etc.)
/.claude/

# Playwright-MCP-Screenshots im Repo-Root — landen sonst versehentlich
# in Commits (siehe mcp__playwright__browser_take_screenshot).
/*.png

# #644: temporäre Design-Previews für hanssiemgroth.de (nicht versionieren)
/public/design-test/

# #735: interne Strategie-/Verlaufsdokumente — lokal behalten, nicht veröffentlichen
/reports/
/prompts/

# Vorlage soll getrackt sein:
!/.env.example

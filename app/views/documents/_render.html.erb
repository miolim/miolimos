<%# #532 (Hans, 2026-06-08) / #926: datengetriebener Render eines Anschreibens
    (Brief/NDA/Lastschrift) auf der DIN-5008-Geometrie (Form B). Der Text
    kommt aus dem verlinkten Body-KI; {{key}}-Platzhalter werden vorher aus
    dem Merge-Kontext gefüllt (#926 Stufe 2). Rechnung/Angebot rendern seit
    #926 in invoices/_render über dasselbe DIN-Gerüst (printables/din_page). %>
<% document = local_assigns.fetch(:document) %>
<% if document.nda? %>
  <%# #562 (Hans): die NDA nutzt NICHT die DIN-Fenster-Geometrie (kein
      Anschriftfeld, kein Infoblock) — eigener, mehrseitiger Vertrags-Layout. %>
  <%= render "documents/render_nda", document: document %>
<% else %>
  <% rows = [] %>
  <% rows << [t("documents.render.your_ref"), document.your_ref] if document.your_ref.present? %>
  <% rows << [t("documents.render.our_ref"),  document.our_ref]  if document.our_ref.present? %>
  <%# Datum oben (Brief-Konvention). %>
  <% rows << [t("documents.render.date"), (l(document.document_date, format: :long) if document.document_date)] %>
  <% rows << [t("documents.render.project"), document.topic.name] if document.topic %>
  <%# #532: freie Key-Value-Felder + ausgewählte Empfänger-IDs. %>
  <% document.info_fields.each { |label, value| rows << [label, value] } %>
  <%= render layout: "printables/din_page", locals: { printable: document, info_rows: rows } do %>
    <% if document.lastschrift? %>
      <%# #786 (Hans): SEPA-Mandat im DIN-Layout — Anschriftfeld (Empfänger=
          Gläubiger, fürs Kuvert-Fenster) oben, das auto-befüllte Formular hier
          im Body. %>
      <%= render "documents/render_lastschrift", document: document %>
    <% else %>
      <%# Prosa: Betreff + Anrede + Body-KI-Text + Gruß/Signatur. %>
      <% if document.subject.present? %><p class="din-subject"><%= document.subject %></p><% end %>
      <p><%= document.salutation_line %>,</p>
      <% if document.body_ki %>
        <%# #926 Stufe 2: {{key}}-Merge auf dem Markdown-ROHTEXT, vor dem
            KI-Renderer — unaufgelöste Platzhalter bleiben sichtbar stehen. %>
        <div class="markdown-body"><%= KnowledgeMarkdown.render(TemplateMerge.merge(document.body_ki.body.to_s, document.merge_context)).html_safe %></div>
      <% end %>
      <p class="din-greeting"><%= t("documents.render.greeting") %></p>
      <div class="din-signature <%= 'din-signed' if @signed %>">
        <%# #547: bei der signierten Ausgabe ein sichtbarer Vermerk über der
            Linie; die kryptografische AES-Signatur liegt zusätzlich im PDF. %>
        <% if @signed %>
          <%# #547: Unterschriftsbild ragt mit dem unteren Teil über Vermerk +
              Linie (negatives margin-bottom + z-index, wie händisch über der
              Linie signiert). PNG mit transparentem Grund wirkt am besten. %>
          <% if @signature_image.present? %>
            <img src="<%= @signature_image %>" alt="<%= t("documents.render.signature_alt") %>"
                 style="display:block; max-height:22mm; margin-bottom:-12mm; position:relative; z-index:2;">
          <% end %>
          <div style="font-size:7.5pt; color:#000; margin-bottom:1mm; position:relative; z-index:1;"><%= t("documents.render.signed_note", name: document.issuer&.title, date: l(Date.current, format: :long)) %></div>
        <% end %>
        <div class="line">&nbsp;</div>
        <div class="name"><%= document.issuer&.title.presence || "—" %></div>
      </div>
    <% end %>
  <% end %>
<% end %>

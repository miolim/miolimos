<%# #532/#548/#559 (Hans): Felder eines Anschreibens. #559: Label-Spalte links
    (Desktop) / oben (Mobil), gleich breit für alle Felder, Inhalte (Pillen +
    Felder) linksbündig. Reihenfolge: Projekt, Status, Aussteller, Empfänger,
    Datum, Betreff. Ihr/Unser Zeichen + Infoblock-Felder stehen in
    printables/_infofields. Rechnungs-Felder leben seit #926 in invoices/. %>
<% rowcls = "grid grid-cols-1 sm:grid-cols-[8rem_1fr] sm:items-center gap-x-2 gap-y-0.5" %>
<% inputcls = "w-full border border-slate-200 rounded px-2 py-0.5 bg-white" %>
<%# #562 (Hans): bei der einseitigen NDA heißen die Parteien Erklärender
    (unterzeichnet, zur Vertraulichkeit verpflichtet) und Empfangender (Adressat,
    dessen Informationen geschützt werden) statt Aussteller/Empfänger. %>
<% issuer_label    = document.nda? ? t("documents.fields.declarant")  : t("documents.fields.issuer") %>
<% recipient_label = document.nda? ? t("documents.fields.customer") : t("documents.fields.recipient") %>
<div id="document_fields_<%= document.id %>" class="space-y-1.5 text-[13px]">
  <%# — Projekt — %>
  <div class="<%= rowcls %>">
    <span class="text-slate-500"><%= t("documents.fields.project") %></span>
    <%= render "shared/entity_picker",
          icon: "folder", icon_only: true, placeholder: t("documents.fields.topic_placeholder"), chips_first: true, close_after_pick: true,
          chips_id: "document_topic_chip_#{document.id}", chips_partial: "printables/link_chip",
          chips_locals: { printable: document, field: "topic", record: document.topic },
          suggest_url: suggest_links_documents_path(kind: "topic"),
          add_url: link_document_path(document, field: "topic"),
          param_name: "value", create_label: "", allow_create: false %>
  </div>

  <%# — Status — %>
  <div class="<%= rowcls %>">
    <span class="text-slate-500"><%= t("documents.fields.status") %></span>
    <%= form_with url: document_path(document), method: :patch, local: false, class: "contents" do |f| %>
      <%= f.select :status, Document.statuses.keys.map { |s| [s.capitalize, s] }, { selected: document.status },
            onchange: "this.form.requestSubmit()", class: inputcls %>
    <% end %>
  </div>

  <%# — Aussteller / Erklärender — %>
  <div class="<%= rowcls %>">
    <span class="text-slate-500"><%= issuer_label %></span>
    <%= render "shared/entity_picker",
          icon: "building", icon_only: true, placeholder: t("documents.fields.issuer_placeholder"), chips_first: true, close_after_pick: true,
          chips_id: "document_issuer_chip_#{document.id}", chips_partial: "printables/link_chip",
          chips_locals: { printable: document, field: "issuer", record: document.issuer },
          suggest_url: suggest_links_documents_path(kind: "issuer"),
          add_url: link_document_path(document, field: "issuer"),
          param_name: "value", create_label: "", allow_create: false %>
  </div>

  <%# — Empfänger / Empfangender — %>
  <div class="<%= rowcls %>">
    <span class="text-slate-500"><%= recipient_label %></span>
    <%= render "shared/entity_picker",
          icon: "users", icon_only: true, placeholder: t("documents.fields.recipient_placeholder"), chips_first: true, close_after_pick: true,
          chips_id: "document_recipient_chip_#{document.id}", chips_partial: "printables/link_chip",
          chips_locals: { printable: document, field: "recipient", record: document.recipient },
          suggest_url: suggest_links_documents_path(kind: "recipient"),
          add_url: link_document_path(document, field: "recipient"),
          param_name: "value", create_label: "", allow_create: false %>
  </div>

  <%# #694 (Hans): Anschrift wählen, wenn der Empfänger MEHRERE Postadressen
      hat (z.B. Krankenkasse mit Postfach + Hausanschrift). Leer = automatisch
      (mailing_address). Bei 0/1 Adressen erscheint die Zeile nicht. %>
  <% recipient_addrs = document.recipient&.postal_addresses&.ordered.to_a %>
  <% if recipient_addrs.size > 1 %>
    <div class="<%= rowcls %>">
      <span class="text-slate-500"><%= t("documents.fields.address") %></span>
      <%= form_with url: document_path(document), method: :patch, local: false, class: "contents" do |f| %>
        <%= f.select :recipient_address_id,
              recipient_addrs.map { |a| [a.oneline, a.id] },
              { selected: document.chosen_recipient_address&.id,
                include_blank: t("documents.fields.address_auto", address: document.recipient.mailing_address&.oneline) },
              onchange: "this.form.requestSubmit()", class: inputcls %>
      <% end %>
    </div>
  <% end %>

  <%# #786 Inkr.2 (Hans): beim SEPA-Mandat die Schuldner-Bankverbindung wählen,
      wenn der Aussteller mehrere hat. Bei 0/1 erscheint die Zeile nicht. %>
  <% if document.lastschrift? %>
    <% debtor_accounts = document.issuer&.bank_accounts&.ordered.to_a %>
    <% if debtor_accounts.size > 1 %>
      <div class="<%= rowcls %>">
        <span class="text-slate-500"><%= t("documents.fields.debtor_account") %></span>
        <%= form_with url: document_path(document), method: :patch, local: false, class: "contents" do |f| %>
          <%= f.select :debtor_bank_account_id,
                debtor_accounts.map { |a| [a.display_label, a.id] },
                { selected: document.effective_debtor_account&.id,
                  include_blank: t("documents.fields.debtor_account_auto", account: debtor_accounts.first&.display_label) },
                onchange: "this.form.requestSubmit()", class: inputcls %>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%# — Datum — %>
  <div class="<%= rowcls %>">
    <span class="text-slate-500"><%= t("documents.fields.date") %></span>
    <%= form_with url: document_path(document), method: :patch, local: false, class: "contents" do |f| %>
      <%= f.date_field :document_date, value: document.document_date,
            onchange: "this.form.requestSubmit()", class: inputcls %>
    <% end %>
  </div>

  <%# — Betreff — #623 (Hans): nur Brief (NDA braucht ihn nicht);
      Position unter dem Datum (Hans-Spec v2). Rendert als din-subject. %>
  <% if document.brief? %>
    <div class="<%= rowcls %>">
      <span class="text-slate-500"><%= t("documents.fields.subject") %></span>
      <%= form_with url: document_path(document), method: :patch, local: false, class: "contents" do %>
        <%= text_field_tag :subject, document.subject,
              placeholder: t("documents.fields.subject_placeholder"),
              onblur: "if (this.value !== this.defaultValue) this.form.requestSubmit()",
              class: inputcls %>
      <% end %>
    </div>
  <% end %>

  <%# #541: Anrede + Text (Body-KI) — beim SEPA-Mandat entfällt beides
      (das Formular wird aus den Stammdaten generiert, #786 Inkr.2). %>
  <% unless document.lastschrift? %>
    <div class="<%= rowcls %>">
      <span class="text-slate-500"><%= t("documents.fields.salutation") %> <span class="text-slate-400 font-normal">(<%= t("documents.fields.empty_equals", value: document.salutation_line) %>)</span></span>
      <%= form_with url: document_path(document), method: :patch, local: false, class: "contents" do |f| %>
        <%= text_field_tag :salutation, document.salutation,
              onblur: "if (this.value !== this.defaultValue) this.form.requestSubmit()", class: inputcls %>
      <% end %>
    </div>
    <div class="<%= rowcls %>">
      <span class="text-slate-500"><%= t("documents.fields.text") %></span>
      <div class="flex items-center gap-2 min-w-0">
        <%= render "shared/entity_picker",
              icon: "file_text", icon_only: true, placeholder: t("documents.fields.text_ki_placeholder"), chips_first: true, close_after_pick: true,
              chips_id: "document_body_chip_#{document.id}", chips_partial: "printables/link_chip",
              chips_locals: { printable: document, field: "body", record: document.body_ki },
              suggest_url: suggest_links_documents_path(kind: "body"),
              add_url: link_document_path(document, field: "body"),
              param_name: "value", create_label: "", allow_create: false %>
        <%= button_to create_body_ki_document_path(document), method: :post,
              form: { class: "inline m-0 p-0", data: { turbo_stream: true } },
              title: t("documents.fields.new_text_ki_title"), class: "shrink-0 text-[11px] px-1.5 py-0.5 rounded border border-slate-200 text-emerald-700 hover:bg-emerald-50 cursor-pointer" do %><%= t("documents.fields.new_short") %><% end %>
      </div>
    </div>
    <%# #926 Stufe 2: Platzhalter im Body-Text, die der Merge-Kontext (noch)
        nicht füllt — sichtbar machen statt still im Dokument stehen lassen. %>
    <% if document.body_ki && (unresolved = TemplateMerge.unresolved(document.body_ki.body.to_s, document.merge_context)).any? %>
      <div class="text-xs px-2 py-1 rounded bg-amber-50 text-amber-800 border border-amber-200">
        <%= t("documents.fields.unresolved_placeholders", keys: unresolved.map { |k| "{{#{k}}}" }.join(", ")) %>
      </div>
    <% end %>
  <% end %>
</div>

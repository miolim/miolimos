<%# Source-Card im Stack — analog knowledge_items/_stack_card.
    data-uuid bekommt einen "src:"-Prefix, damit der blade-stack-Controller
    Source-Cards von KI-Cards unterscheiden kann. Der editierbare
    Inhalt steckt im _stack_card_detail-Partial, eingebettet in einen
    TurboFrame, sodass Inline-Edits (auto-submit on-blur) ohne Page-
    Reload aktualisiert werden.
    Locals: source. %>
<article id="stack_card_src_<%= source.slug %>"
         data-uuid="src:<%= source.slug %>"
         class="stack-card shrink-0 relative
                w-[36rem] max-w-[calc(100vw-3rem)]
                bg-white border-l border-slate-200 first:border-l-0
                flex">

  <aside class="stack-spine self-stretch w-7 shrink-0
                bg-blue-50 border-r border-blue-200
                flex flex-col items-center pt-2 gap-2
                cursor-pointer hover:bg-blue-100"
         title="<%= t("sources.stack_card.spine_title", title: source.title) %>"
         data-action="click->blade-stack#focusCard dblclick->blade-stack#toggleCollapse"
         data-target-uuid="src:<%= source.slug %>">
    <span class="shrink-0 text-blue-700"><%= icon "book_open" %></span>
    <%# #630: Quellen-Wikilink [[&slug]] kopieren. %>
    <%= blade_copy_button("src:#{source.slug}") %>
    <%# #296: rotate-180 raus — Title soll oben unter dem Icon starten
        und nach unten laufen, konsistent mit Task/KI/Communication-
        Spines. Vorher lief der Title bottom-up vom Spine-Boden. %>
    <span class="text-xs text-blue-900 font-medium whitespace-nowrap overflow-hidden text-ellipsis
                 [writing-mode:vertical-rl] min-h-0 flex-1">
      <%= source.title %>
    </span>
    <%= render "shared/blade_close_button" %>
  </aside>

  <div class="flex-1 min-w-0 min-h-0 overflow-y-auto p-4">
    <%= render "sources/stack_card_detail", source: source %>
  </div>
</article>

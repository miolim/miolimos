<%# #536: Layout des Kundenportals. Bewusst OHNE App-Assets (kein Tailwind-
    Link, kein JS): das CSS steht inline — jede Seite ist dadurch
    selbst-enthalten und der statische Export (P4) ist ein simples
    Abspeichern derselben Seiten. UX absichtlich luftiger/leichter als
    das Hauptprogramm (Hans: Kunden brauchen weniger Informationsdichte). %>
<!doctype html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= content_for(:title).presence || t("portal.layout.brand") %></title>
  <%= csrf_meta_tags %>
  <style>
    :root { --ink:#1f2937; --soft:#6b7280; --line:#e5e7eb; --accent:#047857; --bg:#f8fafc; }
    * { box-sizing: border-box; }
    body { margin:0; background:var(--bg); color:var(--ink);
           font: 16px/1.65 -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif; }
    .wrap { max-width: 760px; margin: 0 auto; padding: 2.5rem 1.25rem 4rem; }
    header.site { display:flex; align-items:baseline; justify-content:space-between;
                  gap:1rem; flex-wrap:wrap; margin-bottom:.75rem; }
    .brand { font-weight:700; letter-spacing:.02em; font-size:1.05rem; color:var(--accent); text-decoration:none; }
    nav.main { display:flex; gap:1.1rem; flex-wrap:wrap; padding:.6rem 0 1.8rem;
               border-bottom:1px solid var(--line); margin-bottom:2rem; }
    nav.main a { color:var(--soft); text-decoration:none; font-size:.95rem; }
    nav.main a.active, nav.main a:hover { color:var(--ink); }
    h1 { font-size:1.55rem; line-height:1.3; margin:0 0 1.2rem; font-weight:650; }
    h2 { font-size:1.05rem; margin:2rem 0 .8rem; font-weight:650; }
    p  { margin:.4rem 0; }
    .muted { color:var(--soft); font-size:.92rem; }
    .card { background:#fff; border:1px solid var(--line); border-radius:10px;
            padding:1.1rem 1.25rem; margin:.7rem 0; }
    .row  { display:flex; justify-content:space-between; gap:1rem; align-items:baseline; flex-wrap:wrap; }
    .pill { display:inline-block; font-size:.78rem; padding:.15rem .6rem; border-radius:999px;
            border:1px solid var(--line); color:var(--soft); white-space:nowrap; }
    .pill.done    { background:#ecfdf5; border-color:#a7f3d0; color:#047857; }
    .pill.active  { background:#eff6ff; border-color:#bfdbfe; color:#1d4ed8; }
    a.button, button.primary { display:inline-block; background:var(--accent); color:#fff; border:0;
            border-radius:8px; padding:.55rem 1.1rem; font-size:.95rem; cursor:pointer; text-decoration:none; }
    input[type=email], textarea { width:100%; border:1px solid var(--line); border-radius:8px;
            padding:.6rem .8rem; font:inherit; background:#fff; }
    textarea { min-height:7rem; resize:vertical; }
    form.stack > * + * { margin-top:.8rem; }
    .msg { border-left:3px solid var(--line); padding:.5rem 1rem; margin:.9rem 0; }
    .msg.customer { border-color:#bfdbfe; }
    .msg.us       { border-color:#a7f3d0; }
    .flash { border-radius:8px; padding:.7rem 1rem; margin:0 0 1.4rem; font-size:.95rem; }
    .flash.notice { background:#ecfdf5; color:#065f46; }
    .flash.alert  { background:#fef2f2; color:#991b1b; }
    footer.site { margin-top:3.5rem; padding-top:1.2rem; border-top:1px solid var(--line); }
    table { width:100%; border-collapse:collapse; }
    td, th { text-align:left; padding:.5rem .4rem; border-bottom:1px solid var(--line); vertical-align:top; }
    th { font-size:.82rem; color:var(--soft); font-weight:600; }
  </style>
</head>
<body>
  <div class="wrap">
    <header class="site">
      <a class="brand" href="<%= portal_href(portal_root_path, "index.html") %>"><%= t("portal.layout.brand") %></a>
      <span class="muted">
        <% if portal_topic && !@export %>
          <%= portal_topic.name %> ·
          <%= button_to t("portal.layout.sign_out"), portal_session_path, method: :delete,
                form: { style: "display:inline" },
                style: "background:none;border:0;padding:0;color:#6b7280;cursor:pointer;font:inherit;text-decoration:underline" %>
        <% elsif portal_topic %>
          <%= portal_topic.name %> · <%= t("portal.layout.archive") %>
        <% end %>
        <%# #619 Stufe 3: Sprachumschalter (nur live — Export ist ein
            Snapshot in einer Sprache). %>
        <% unless @export %>
          <span style="margin-left:.5rem; white-space:nowrap">
            <% if I18n.locale.to_s == "de" %><strong style="color:var(--ink)">DE</strong><% else %><a href="<%= portal_set_locale_path("de") %>" style="color:#6b7280;text-decoration:none">DE</a><% end %>
            <span style="color:var(--line)">·</span>
            <% if I18n.locale.to_s == "en" %><strong style="color:var(--ink)">EN</strong><% else %><a href="<%= portal_set_locale_path("en") %>" style="color:#6b7280;text-decoration:none">EN</a><% end %>
          </span>
        <% end %>
      </span>
    </header>
    <% if portal_topic %>
      <nav class="main">
        <a href="<%= portal_href(portal_root_path, "index.html") %>" class="<%= 'active' if !@export && current_page?(portal_root_path) %>"><%= t("portal.nav.overview") %></a>
        <a href="<%= portal_href(portal_roadmap_path, "roadmap.html") %>" class="<%= 'active' if !@export && current_page?(portal_roadmap_path) %>"><%= t("portal.nav.roadmap") %></a>
        <a href="<%= portal_href(portal_termine_path, "termine.html") %>" class="<%= 'active' if !@export && current_page?(portal_termine_path) %>"><%= t("portal.nav.appointments") %></a>
        <a href="<%= portal_href(portal_dokumente_path, "dokumente.html") %>" class="<%= 'active' if !@export && current_page?(portal_dokumente_path) %>"><%= t("portal.nav.documents") %></a>
        <a href="<%= portal_href(portal_nachrichten_path, "nachrichten.html") %>" class="<%= 'active' if !@export && current_page?(portal_nachrichten_path) %>"><%= t("portal.nav.messages") %></a>
      </nav>
    <% end %>

    <% if notice.present? %><div class="flash notice"><%= notice %></div><% end %>
    <% if alert.present? %><div class="flash alert"><%= alert %></div><% end %>

    <%= yield %>

    <footer class="site muted">
      <%= portal_topic&.name || t("portal.layout.brand") %> · <%= t("portal.layout.provided_by") %><%= " · #{t("portal.layout.as_of", date: l(Date.current, format: :long))}" if @export %>
    </footer>
  </div>
</body>
</html>

<%# #533 #2b (Hans, 2026-06-07): Detail-Blade einer Zeitbuchung — Ereignis-Log
    (Start/Ende-Aktionen) + Bearbeiten von Start/Ende bzw. nur Dauer. %>
<% stack_id = "time:#{entry.id}" %>
<div id="stack_card_<%= stack_id %>"
     class="stack-card shrink-0 relative w-[26rem] max-w-[calc(100vw-3rem)]
            bg-white border-l border-slate-200 first:border-l-0 flex"
     data-uuid="<%= stack_id %>">
  <%= render "shared/blade_spine", stack_id: stack_id, title: t("time_entries.entry"),
        icon_html: icon("timer"), label: t("time_entries.entry"), topics: [entry.topic] %>

  <div class="flex-1 min-w-0 min-h-0 overflow-y-auto p-4 space-y-3"
       data-controller="time-edit"
       data-time-edit-url-value="<%= update_times_time_entry_path(entry) %>"
       data-time-edit-card-url-value="<%= card_time_entry_path(entry) %>"
       data-time-edit-destroy-url-value="<%= time_entry_path(entry) %>">
    <div>
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full shrink-0
                     <%= entry.running? ? 'bg-emerald-500' : (entry.paused? ? 'bg-amber-400' : 'bg-slate-300') %>"></span>
        <h2 class="font-semibold text-sm"><%= t("time_entries.entry") %> · <%= format_minutes(entry.duration_minutes) %></h2>
        <%# #1005 (Hans): Card an Dashboard-Stack anhängen — in allen Card-Köpfen. %>
        <span class="ml-auto"><%= render "shared/append_dashboard_button", size: "w-4 h-4" %></span>
        <%# #533 (Hans-Wunsch): Buchung löschen, rechts oben. %>
        <button type="button" data-action="time-edit#destroy"
                title="<%= t("time_entries.delete_entry") %>" aria-label="<%= t("actions.delete") %>"
                class="ml-auto p-1 rounded text-slate-400 hover:bg-rose-50 hover:text-rose-600 cursor-pointer">
          <%= icon "trash", size: "w-4 h-4" %>
        </button>
      </div>
      <p class="text-xs text-slate-500 mt-1 break-words">
        <% if (lbl = time_entry_subject_label(entry)) %><%= lbl %><% end %>
        <% if entry.topic %> · <%= entry.topic.name %><% end %>
        <% if entry.note.present? %> · <%= entry.note %><% end %>
      </p>
    </div>

    <%# Ereignis-Log (#2). %>
    <div>
      <div class="text-[10px] uppercase tracking-wide text-slate-400 mb-1"><%= t("time_entries.history") %></div>
      <ul class="space-y-1 text-xs">
        <% entry.events.each do |ev| %>
          <li class="flex items-start gap-2">
            <span class="font-mono tabular-nums text-slate-400 w-24 shrink-0"><%= ev[:at]&.strftime("%d.%m. %H:%M") %></span>
            <span class="text-slate-700"><%= ev[:label] %></span>
          </li>
        <% end %>
        <% if entry.events.empty? %><li class="text-slate-400"><%= t("time_entries.no_events") %></li><% end %>
      </ul>
    </div>

    <%# #541: Abrechenbar-Schalter — bestimmt, ob die Buchung für Rechnungen
        zur Verfügung steht. %>
    <div class="border-t border-slate-100 pt-2">
      <label class="flex items-center gap-2 text-xs text-slate-600 cursor-pointer">
        <%= form_with url: set_billable_time_entry_path(entry), method: :patch, local: false, class: "contents" do %>
          <input type="hidden" name="billable" value="0">
          <input type="checkbox" name="billable" value="1" <%= "checked" if entry.billable? %>
                 onchange="this.form.requestSubmit()" class="rounded border-slate-300">
          <span><%= t("time_entries.billable") %> <span class="text-emerald-600">€</span></span>
        <% end %>
      </label>
    </div>

    <%# Bearbeiten (#3/#4). %>
    <div class="border-t border-slate-100 pt-2 space-y-2">
      <div class="text-[10px] uppercase tracking-wide text-slate-400"><%= t("actions.edit") %></div>
      <label class="block text-xs text-slate-600"><%= t("time_entries.start") %>
        <input type="datetime-local" data-time-edit-target="startedAt"
               value="<%= entry.started_at&.strftime('%Y-%m-%dT%H:%M') %>"
               class="mt-0.5 w-full rounded border border-slate-200 px-2 py-1">
      </label>
      <label class="block text-xs text-slate-600"><%= t("time_entries.end") %>
        <input type="datetime-local" data-time-edit-target="endedAt"
               value="<%= entry.ended_at&.strftime('%Y-%m-%dT%H:%M') %>"
               class="mt-0.5 w-full rounded border border-slate-200 px-2 py-1">
      </label>
      <button type="button" data-action="time-edit#saveTimes"
              class="text-xs px-2 py-1 rounded bg-emerald-600 text-white hover:bg-emerald-700 cursor-pointer">
        <%= t("time_entries.save_start_end") %>
      </button>
      <div class="flex items-center gap-2 pt-1">
        <input type="number" min="1" step="1" data-time-edit-target="minutes" placeholder="<%= t("time_entries.duration_min") %>"
               class="w-28 rounded border border-slate-200 px-2 py-1 text-xs">
        <button type="button" data-action="time-edit#saveDuration"
                class="text-xs px-2 py-1 rounded bg-slate-100 hover:bg-slate-200 cursor-pointer">
          <%= t("time_entries.set_duration_only") %>
        </button>
      </div>
      <p data-time-edit-target="error" class="hidden text-xs text-rose-600"></p>
    </div>
  </div>
</div>

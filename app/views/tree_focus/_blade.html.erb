<%# #592 Z2: Fokusansicht-Blade. Locals: entry (WorkNode, Blade-Identität),
    focus (WorkNode, aktueller Cursor). Navigation in-place über das
    Turbo-Frame (Links mit ?focus=…). %>
<%
  topic = entry.topic
  stack_uuid = "treefocus:#{entry.id}"
%>
<article id="stack_card_<%= stack_uuid %>"
         data-uuid="<%= stack_uuid %>"
         class="stack-card shrink-0 relative
                w-[34rem] max-w-[calc(100vw-3rem)]
                bg-white border-l border-slate-200 first:border-l-0
                flex">
  <%# #740 (Hans): Spine-Hintergrund rot (wie der Werk-Render-Button),
      network-Icon + Label weiß. %>
  <%= render "shared/list_blade_spine",
        variant: "tree",
        title: t("tree_focus.spine_title", name: topic.name),
        icon_html: icon("network", size: "w-4 h-4"),
        icon_class: "text-white mt-1",
        label: t("tree_focus.spine_label", name: topic.name) %>

  <div class="flex-1 min-w-0 min-h-0 overflow-y-auto p-3">
    <%# #1005 (Hans): Card an Dashboard-Stack anhängen — in allen Card-Köpfen.
        Das Fokus-Blade hat keinen eigenen Kopf; schmale Icon-Zeile oben rechts. %>
    <div class="flex justify-end -mt-1 -mr-1">
      <%= render "shared/append_dashboard_button", size: "w-4 h-4" %>
    </div>
    <%= turbo_frame_tag "tree_focus_frame_#{entry.id}" do %>
      <%= render "tree_focus/panel", entry: entry, focus: focus %>
    <% end %>
  </div>
</article>

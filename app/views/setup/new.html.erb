<% content_for :title, t("setup.heading") %>

<div class="w-full max-w-sm rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
  <div class="flex items-center gap-2 mb-4">
    <span class="inline-block w-2 h-2 rounded-full bg-emerald-400"></span>
    <span class="font-semibold text-slate-900">miolimOS</span>
  </div>
  <h1 class="text-lg font-semibold mb-1"><%= t("setup.heading") %></h1>
  <p class="text-sm text-slate-600 mb-4"><%= t("setup.intro") %></p>

  <% if @actor.errors.any? %>
    <div class="mb-3 rounded border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700">
      <ul class="list-disc list-inside">
        <% @actor.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @actor, url: setup_path, method: :post, local: true do |f| %>
    <div class="mb-3">
      <%= f.label :name, t("setup.name"), class: "block text-xs text-slate-600 mb-1" %>
      <%= f.text_field :name, autofocus: true, required: true,
            class: "w-full rounded border border-slate-200 px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-emerald-400" %>
    </div>
    <div class="mb-3">
      <%= f.label :email, t("setup.email"), class: "block text-xs text-slate-600 mb-1" %>
      <%= f.email_field :email, required: true,
            class: "w-full rounded border border-slate-200 px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-emerald-400" %>
    </div>
    <div class="mb-3">
      <%= f.label :password, t("setup.password"), class: "block text-xs text-slate-600 mb-1" %>
      <%= f.password_field :password, required: true, minlength: 8,
            class: "w-full rounded border border-slate-200 px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-emerald-400" %>
      <p class="text-xs text-slate-400 mt-1"><%= t("setup.password_hint") %></p>
    </div>
    <div class="mb-4">
      <%= f.label :password_confirmation, t("setup.password_confirmation"), class: "block text-xs text-slate-600 mb-1" %>
      <%= f.password_field :password_confirmation, required: true, minlength: 8,
            class: "w-full rounded border border-slate-200 px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-emerald-400" %>
    </div>
    <%= f.submit t("setup.submit"),
          class: "w-full rounded bg-emerald-600 text-white font-medium py-1.5 hover:bg-emerald-700 cursor-pointer" %>
  <% end %>
</div>

<%# #163 Phase 5b + #217: Awaiting-Blade nutzt jetzt den vollen
    detail_body (statt Glance), damit Edits direkt im Stack
    moeglich sind. %>
<% stack_id = "awaiting:#{awaiting.id}" %>
<article id="stack_card_<%= stack_id %>"
         data-uuid="<%= stack_id %>"
         <% if local_assigns[:focus_title] %>data-focus-after-add="title"<% end %>
         class="stack-card shrink-0 relative
                w-[36rem] max-w-[calc(100vw-3rem)]
                bg-white border-l border-slate-200 first:border-l-0
                flex">

  <%= render "shared/blade_spine", stack_id: stack_id, title: awaiting.title,
        icon_class: awaiting.overdue? ? "text-rose-500" : "text-amber-500",
        icon_html: "⏳", label: awaiting.title, topics: awaiting.topics %>

  <div class="flex-1 min-w-0 min-h-0 overflow-y-auto p-4">
    <%# #868: Card-Werkzeugleiste über das gemeinsame Partial (nur Schließen;
        sticky-Container wie zuvor). %>
    <%= render "shared/blade_toolbar", uuid: stack_id,
          toolbar_class: "sticky -top-4 -mx-4 -mt-4 px-4 pt-2 pb-2 bg-white/95 backdrop-blur z-20",
          duplicate: false, reload: false, focus: false %>

    <div class="mt-3">
      <%= render "awaitings/detail_body", awaiting: awaiting %>
    </div>
  </div>
</article>

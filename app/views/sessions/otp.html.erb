<%# #1051: Login-Schritt 2 — TOTP-Code aus der Authenticator-App oder
    ein Recovery-Code (ein Feld für beides, der Server probiert beide). %>
<% content_for :title, t("sessions.otp_heading") %>

<div class="w-full max-w-sm rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
  <div class="flex items-center gap-2 mb-4">
    <span class="inline-block w-2 h-2 rounded-full bg-emerald-400"></span>
    <span class="font-semibold text-slate-900">miolimOS</span>
  </div>
  <h1 class="text-lg font-semibold mb-2"><%= t("sessions.otp_heading") %></h1>
  <p class="text-xs text-slate-500 mb-4"><%= t("sessions.otp_hint") %></p>

  <%= form_with url: login_otp_path, method: :post, local: true do |f| %>
    <div class="mb-4">
      <%= f.label :code, t("sessions.otp_code"), class: "block text-xs text-slate-600 mb-1" %>
      <%= f.text_field :code, autofocus: true, required: true,
            autocomplete: "one-time-code", inputmode: "numeric",
            class: "w-full rounded border border-slate-200 px-3 py-1.5 font-mono tracking-widest focus:outline-none focus:ring-2 focus:ring-emerald-400" %>
    </div>
    <%= f.submit t("sessions.otp_submit"),
          class: "w-full rounded bg-emerald-600 text-white font-medium py-1.5 hover:bg-emerald-700 cursor-pointer" %>
  <% end %>

  <p class="mt-3 text-xs">
    <%= link_to t("sessions.otp_back"), login_path, class: "text-slate-500 hover:text-slate-800" %>
  </p>
</div>

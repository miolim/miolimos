<%# #532: nach Setzen/Lösen einer Verknüpfung den passenden Chip ersetzen. %>
<% record = case @field
             when "issuer"    then @document.issuer
             when "recipient" then @document.recipient
             when "body"      then @document.body_ki
             when "topic"     then @document.topic
             end %>
<%= turbo_stream.replace "document_#{@field}_chip_#{@document.id}" do %>
  <%= render "printables/link_chip", printable: @document, field: @field, record: record %>
<% end %>

<%# #552 (Hans): Aussteller/Empfänger bestimmen die wählbaren Infoblock-IDs —
    bei deren Wechsel die Kandidatenliste frisch nachladen. %>
<% if %w[issuer recipient].include?(@field) %>
  <%= turbo_stream.replace "document_id_candidates_#{@document.id}" do %>
    <%= render "printables/id_candidates", printable: @document %>
  <% end %>
<% end %>

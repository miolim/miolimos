<%# #613: aus app/views/settings/signatures/show.html.erb in den Einstellungs-Stack gezogen (Blade-Inhalt).
    Daten lädt Settings::BladesController#load_signature. %>

<div class="p-4 max-w-md space-y-4">
  <h1 class="text-lg font-semibold"><%= t("settings.signature.title") %></h1>
  <p class="text-sm text-slate-600"><%= t("settings.signature.intro_html") %></p>

  <% if current_actor.signature_image.present? %>
    <div class="border border-slate-200 rounded p-3 bg-white inline-block">
      <%= image_tag current_actor.signature_image, alt: t("settings.signature.alt"), style: "max-height:80px;" %>
    </div>
    <div>
      <%= button_to t("settings.signature.remove"), settings_signature_path, method: :delete,
            form: { data: { turbo_confirm: t("settings.signature.remove_confirm") } },
            class: "text-xs px-2 py-1 rounded border border-slate-200 text-rose-600 hover:bg-rose-50 cursor-pointer" %>
    </div>
  <% else %>
    <p class="text-slate-400 italic text-sm"><%= t("settings.signature.none_yet") %></p>
  <% end %>

  <%# #547: multipart nötig (Datei-Upload); natives Submit (turbo:false), damit
      der Upload zuverlässig durchläuft. %>
  <%= form_with url: settings_signature_path, method: :patch, multipart: true,
        data: { turbo: false } do %>
    <div class="flex items-center gap-2">
      <input type="file" name="signature" accept="image/png,image/jpeg" required
             class="text-sm">
      <button type="submit" class="text-sm px-3 py-1 rounded bg-emerald-600 text-white hover:bg-emerald-700 cursor-pointer">
        <%= t("settings.signature.upload") %>
      </button>
    </div>
  <% end %>
</div>


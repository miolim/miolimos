<%# #257 follow-up: Listen-Blade fuer Personen & Organisationen.
    Sidebar-Plus an „Personen" appended diese Blade. Self-contained —
    laedt die Liste selbst, funktioniert also auch beim Cross-Page-
    Stack-Restore. Stable-ID: list:persons. %>
<%
  stack_id = "list:persons"
  # #702 (Hans): Bekanntheits-Toggle Alle | Kommunikation | Persönlich
  # bekannt. „Kommunikation" umfasst die persönlich bekannten mit.
  known = params[:known].to_s.presence_in(%w[comm personal])
  scope = KnowledgeItem.where(item_type: [:person, :organization])
  case known
  when "personal"
    scope = scope.where(personally_known: true)
  when "comm"
    scope = scope.where("knowledge_items.personally_known = TRUE OR knowledge_items.uuid IN (SELECT mentioned_uuid FROM communication_mentions)")
  end
  items = scope.order(Arel.sql("LOWER(title) ASC")).limit(200).to_a
  total = KnowledgeItem.where(item_type: [:person, :organization]).count
  known_cfg = { nil        => { label: t("knowledge.list.persons.known_all"),      nxt: "comm" },
                "comm"     => { label: t("knowledge.list.persons.known_comm"),     nxt: "personal" },
                "personal" => { label: t("knowledge.list.persons.known_personal"), nxt: nil } }[known]
%>
<article id="stack_card_<%= stack_id %>"
         data-uuid="<%= stack_id %>"
         class="stack-card shrink-0 relative w-[26rem] max-w-[calc(100vw-3rem)]
                bg-white border-l border-slate-200 first:border-l-0 flex">

  <%= render "shared/list_blade_spine",
        title: t("nav.contacts"),
        icon_html: icon("users"),
        stack_id: stack_id,
        label: t("nav.contacts") %>

  <div class="flex-1 min-w-0 min-h-0 overflow-y-auto p-3 space-y-2"
       data-controller="list-search">
    <%# #1049: Card-Werkzeugleiste wie bei Detail-Cards — vor dem Frame,
        damit In-Place-Reloads sie nicht mitrendern. %>
    <%= render "shared/list_blade_toolbar", stack_id: stack_id %>
   <%= turbo_frame_tag "persons_list_body" do %>
    <%# #703 (Hans): einheitlicher Topbereich. Add = Typ-Picker (Plus),
        Controls = Bekanntheits-Toggle (#702). %>
    <% known_toggle = capture do %>
      <%= link_to list_card_persons_path(known: known_cfg[:nxt]),
            data: { turbo_frame: "persons_list_body" },
            title: t("knowledge.list.persons.known_toggle_title", label: known_cfg[:label]),
            class: "inline-flex shrink-0 items-center gap-1 text-[11px] px-1.5 py-0.5 rounded border border-slate-200 hover:bg-slate-100 text-slate-600 no-underline" do %>
        <%= icon "user-check", size: "w-3.5 h-3.5" %><span class="hidden sm:inline"><%= known_cfg[:label] %></span>
      <% end %>
    <% end %>
    <%= render "shared/list_header",
          lead_icon: "users", title: t("nav.contacts"),
          count: items.size, total: total,
          add:      render("knowledge_items/type_picker", types: %w[person organization]),
          search:   render("shared/list_search", placeholder: t("knowledge.list.persons.search_placeholder")),
          controls: known_toggle %>

    <% if items.empty? %>
      <p class="text-sm text-slate-400 italic py-3"><%= t("knowledge.list.persons.empty") %></p>
    <% else %>
      <ul class="divide-y divide-slate-100 text-[13px]">
        <%# #608: Bekanntheit gebatcht — eine Query für die ganze Liste. %>
        <% comm_known = CommunicationMention.where(mentioned_uuid: items.map(&:uuid)).distinct.pluck(:mentioned_uuid).to_set %>
        <% items.each do |ki| %>
          <li class="group py-1.5 px-1 hover:bg-slate-50 flex items-center gap-2">
            <%# #840: Status (persönlich bekannt / Kommunikation) steckt im
                Haupticon (Form+Farbe) — kein separates Badge mehr. %>
            <span class="shrink-0 text-slate-500"><%= knowledge_type_icon(ki, size: "w-4 h-4", known_via_comm: comm_known.include?(ki.uuid)) %></span>
            <%= link_to ki.title,
                  knowledge_item_path(ki.uuid),
                  data: { action: "click->blade-stack#openFromList", target_uuid: ki.uuid },
                  class: "flex-1 hover:underline truncate text-slate-700" %>
            <button type="button"
                    data-action="click->blade-stack#appendFromList"
                    data-target-uuid="<%= ki.uuid %>"
                    title="<%= t('knowledge.list.persons.append_title') %>"
                    aria-label="<%= t('knowledge.list.persons.append_aria') %>"
                    class="flex md:hidden md:group-hover:flex shrink-0 items-center justify-center
                           w-5 h-5 rounded text-slate-400 bg-transparent border-0
                           hover:bg-emerald-50 hover:text-emerald-700 cursor-pointer
                           leading-none text-base">
              +
            </button>
          </li>
        <% end %>
      </ul>
      <p data-list-search-target="empty" class="hidden text-xs text-slate-400 italic py-2"><%= t("knowledge.list.persons.no_results") %></p>
    <% end %>
   <% end %>
  </div>
</article>

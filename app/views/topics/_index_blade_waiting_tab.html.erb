<%# #163 Phase 6d: Wartepunkt-Tab innerhalb der list:topic-Card.
    Detail-Klicks gehen via blade-link (awaitings/_row mit blade_kind/
    blade_id Locals) an den outer blade-stack.
    #484 Increment C (Hans, 2026-06-03): auf das gemeinsame Tab-Gerüst
    (topics/tab_shell) umgestellt — einheitliche Breite/Struktur. Quick-Add
    bleibt das Wartepunkt-eigene Formular (awaitings/quickadd_form). %>
<%
  # #348 Phase 3: Lazy-Load fuer Dashboard-Stack-Loader-Pfad.
  @awaitings ||= topic.awaitings.open.includes(:contact_ki).order(:follow_up_at).limit(200).to_a
%>
<%= render layout: "topics/tab_shell",
      locals: {
        title:        t("topics.tabs.waiting"),
        count:        @awaitings.size,
        row_selector: "li[id^='awaiting_row_']",
        quick_add:    render("awaitings/quickadd_form", topic: topic),
        empty:        @awaitings.any?
      } do %>
  <% if @awaitings.empty? %>
    <p id="awaitings_empty" class="px-4 py-3 text-slate-500 italic"><%= t("dashboard.no_awaitings") %></p>
  <% end %>
  <ul id="awaitings_list" class="flex flex-col">
    <% @awaitings.each do |awaiting| %>
      <%= render "awaitings/row", awaiting: awaiting,
            blade_kind: "awaiting", blade_id: awaiting.id %>
    <% end %>
  </ul>
<% end %>

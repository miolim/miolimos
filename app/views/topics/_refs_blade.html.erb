<%# #352 Hans-Follow (2026-05-25): Topic-Variante des Reference-Blades.
    Listet alle Wikilink-Ziele aus allen KIs im Work-Tree des Topics
    auf (Tree-Walk + Dedup ueber WikilinkTargets.for_topic).

    Locals: topic (Topic). %>
<%
  stack_uuid = "refs:topic:#{topic.slug}"
  targets    = WikilinkTargets.for_topic(topic)
%>
<article id="stack_card_<%= stack_uuid %>"
         data-uuid="<%= stack_uuid %>"
         class="stack-card shrink-0 relative
                w-[44rem] max-w-[calc(100vw-3rem)]
                bg-white border-l border-slate-200 first:border-l-0
                flex">

  <%= render "shared/list_blade_spine",
        title: "Referenzen aus Work-Tree \u201e#{topic.name}",
        pre_icon: tag.span(class: "inline-block w-3 h-3 rounded-full shrink-0 mt-1 bg-amber-400"),
        icon_html: icon("file_output"),
        icon_class: "text-slate-600 [&_svg]:w-5 [&_svg]:h-5",
        label: "#{topic.name} \u00b7 Refs" %>

  <div class="flex-1 min-w-0 min-h-0 overflow-y-auto">
    <header class="sticky top-0 z-20 px-3 py-2 bg-white/95 backdrop-blur border-b border-slate-200 flex items-center gap-2">
      <h2 class="font-semibold text-sm"><%= t("topics.references") %></h2>
      <span class="text-xs text-slate-500">aus Work-Tree „<%= topic.name %>“</span>
      <span class="text-xs text-slate-400 ml-auto"><%= targets.size %></span>
      <%# #360 (Hans, 2026-05-25): Per-Blade-Reload. %>
      <button type="button"
              data-action="click->blade-stack#reloadCard"
              title="<%= t("tasks.reload_card") %>"
              class="p-1 rounded text-slate-500 hover:bg-slate-100 hover:text-slate-900 cursor-pointer">
        <%= icon "refresh", size: "w-3.5 h-3.5" %>
      </button>
    </header>

    <% if targets.empty? %>
      <p class="px-4 py-6 text-sm text-slate-400 italic">
        Keine aufloesbaren Wikilinks in den KIs dieses Work-Trees.
      </p>
    <% else %>
      <div class="divide-y divide-slate-200 min-h-full">
        <% targets.each do |t|
             body_html = t.body.present? ? KnowledgeMarkdown.render(t.body, item: t) : ""
             first_para_html, rest_html =
               if (m = body_html.match(/\A(.*?<\/p>)(.*)\z/m))
                 [m[1], m[2]]
               else
                 [body_html, ""]
               end
        %>
          <section data-controller="ref-cycle"
                   data-ref-cycle-state-value="0"
                   class="ref-item px-3 py-2">
            <header class="flex items-baseline gap-2">
              <button type="button"
                      data-action="click->ref-cycle#cycle"
                      title="<%= t("topics.toggle_content_mode") %>"
                      class="shrink-0 p-0.5 -ml-1 rounded text-slate-400 hover:text-slate-800 hover:bg-slate-100 cursor-pointer">
                <span data-ref-cycle-target="icon"
                      class="inline-block transition-transform">
                  <%= icon "chevron_right", size: "w-3.5 h-3.5" %>
                </span>
              </button>
              <a href="<%= knowledge_item_path(t.uuid) %>"
                 data-action="click->blade-stack#openInStack"
                 data-target-uuid="<%= t.uuid %>"
                 class="flex-1 min-w-0 text-sm font-medium text-slate-800 hover:underline">
                <%= t.title %>
              </a>
              <% if t.item_type.present? %>
                <span class="shrink-0 text-[10px] uppercase tracking-wider text-slate-400">
                  <%= t.item_type %>
                </span>
              <% end %>
            </header>

            <% if first_para_html.present? || rest_html.present? %>
              <div data-ref-cycle-target="firstPara"
                   class="markdown-body mt-2 hidden">
                <%= raw first_para_html %>
              </div>
              <% if rest_html.present? %>
                <div data-ref-cycle-target="fullRest"
                     class="markdown-body hidden">
                  <%= raw rest_html %>
                </div>
              <% end %>
            <% else %>
              <p class="mt-1 ml-6 text-xs text-slate-400 italic">— kein Inhalt —</p>
            <% end %>
          </section>
        <% end %>
      </div>
    <% end %>
  </div>
</article>

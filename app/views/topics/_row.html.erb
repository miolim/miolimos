<%# Zeile in der Themen-Liste — klickbar, Detail lädt rechts in Turbo-Frame. %>
<li id="topic_row_<%= topic.id %>"
    data-topic-slug="<%= topic.slug %>"
    class="px-4 py-2 flex items-center gap-3 border-l-4 border-l-transparent data-[active=true]:border-l-slate-700 data-[active=true]:bg-slate-50 hover:bg-slate-50">
  <%= topic_dot topic %>
  <%# #756 (Hans, 2026-06-23): Blade-Append statt topic_detail-Frame. %>
  <%= link_to topic.name, topic_path(topic),
        data: { controller: "blade-link", "blade-link-kind-value": "topic",
                "blade-link-id-value": topic.slug, action: "click->blade-link#append",
                turbo_frame: "_top" },
        class: "text-slate-900 hover:underline flex-1 truncate" %>
  <% if topic.template? %>
    <span class="text-xs text-indigo-700 bg-indigo-50 px-2 py-0.5 rounded"><%= t("topics.template") %></span>
  <% else %>
    <%= status_badge topic.status, labels: { "active" => t("topics.status.active"), "inactive" => t("topics.status.inactive") } %>
  <% end %>
  <span class="text-xs text-slate-400 font-mono w-32 text-right truncate"><%= topic.slug %></span>
</li>

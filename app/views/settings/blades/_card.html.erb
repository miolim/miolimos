<%# #613: generischer Stack-Card-Wrapper für eine Einstellungs-Seite.
    Locals: page (Key aus Settings::BladesController::PAGES), label.
    Inhalt = settings/blades/_<page> (1:1 die alte Seiten-Substanz). %>
<article id="stack_card_settings:<%= page %>"
         data-uuid="settings:<%= page %>"
         class="stack-card shrink-0 relative w-[44rem] max-w-[calc(100vw-3rem)]
                bg-white border-l border-slate-200 first:border-l-0 flex">

  <%= render "shared/blade_spine", stack_id: "settings:#{page}",
        title: label,
        icon_html: icon(Settings::BladesController::PAGES.fetch(page)[:icon]),
        label: label %>

  <div class="flex-1 min-w-0 min-h-0 overflow-y-auto p-4 space-y-3">
    <header class="sticky -top-4 -mx-4 -mt-4 px-4 pt-4 pb-2 bg-white/95 backdrop-blur z-20
                   border-b border-slate-100 flex items-center gap-2">
      <span class="text-slate-500 [&_svg]:w-4 [&_svg]:h-4"><%= icon Settings::BladesController::PAGES.fetch(page)[:icon] %></span>
      <span class="flex-1 min-w-0 truncate font-semibold"><%= label %></span>
    </header>
    <%= render "settings/blades/#{page}" %>
  </div>
</article>

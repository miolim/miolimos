<%# #613: aus app/views/settings/preferences/show.html.erb in den Einstellungs-Stack gezogen (Blade-Inhalt).
    Daten lädt Settings::BladesController#load_preferences. %>
  
  <%= form_with url: settings_preferences_path, method: :patch,
        class: "bg-white rounded border border-slate-200 divide-y divide-slate-100",
        data: { turbo: false } do |f| %>

    <%# #619 (Hans): UI-Sprache pro Nutzer (DE/EN). %>
    <section class="px-4 py-3">
      <h2 class="text-sm font-semibold text-slate-900 mb-1"><%= t("preferences.language_title") %></h2>
      <p class="text-xs text-slate-500 mb-3"><%= t("preferences.language_help") %></p>
      <select name="preferences[locale]"
              class="text-sm border border-slate-300 rounded px-2 py-1 focus:outline-none focus:border-emerald-400">
        <% ActorPreferences::LOCALES.each do |loc| %>
          <option value="<%= loc %>" <%= "selected" if current_actor.pref_locale == loc %>><%= t("languages.#{loc}") %></option>
        <% end %>
      </select>
    </section>

    <%# #1027 (Hans): Womit „E-Mail schreiben" öffnet — Gmail im Browser oder
        der Standard-Mail-Client (mailto:). "auto" wählt Gmail nur, wenn ein
        eigenes Google-Konto verbunden ist. %>
    <section class="px-4 py-3">
      <h2 class="text-sm font-semibold text-slate-900 mb-1"><%= t("preferences.mail_compose_title") %></h2>
      <p class="text-xs text-slate-500 mb-3"><%= t("preferences.mail_compose_help") %></p>
      <% stored = ActorPreferences::MAIL_COMPOSE_TARGETS.include?(current_actor.preferences["mail_compose"].to_s) ? current_actor.preferences["mail_compose"] : "auto" %>
      <div class="flex flex-col gap-1 text-sm">
        <% ActorPreferences::MAIL_COMPOSE_TARGETS.each do |target| %>
          <label class="flex items-center gap-1.5">
            <input type="radio" name="preferences[mail_compose]" value="<%= target %>"
                   <%= "checked" if stored == target %>>
            <span><%= t("preferences.mail_compose_#{target}") %></span>
          </label>
        <% end %>
      </div>
    </section>

    <section class="px-4 py-3">
      <h2 class="text-sm font-semibold text-slate-900 mb-1"><%= t("preferences.card_widths_title") %></h2>
      <p class="text-xs text-slate-500 mb-3"><%= t("preferences.card_widths_help") %></p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 text-sm">
        <% current_actor.pref_card_widths.each do |kind, width| %>
          <label class="flex items-center gap-2">
            <span class="w-32 text-slate-700"><%= kind %></span>
            <input type="number" name="preferences[card_widths][<%= kind %>]"
                   value="<%= width.to_i %>" min="16" max="120" step="1"
                   class="w-20 rounded border border-slate-200 px-2 py-1 tabular-nums">
            <span class="text-xs text-slate-400">rem</span>
          </label>
        <% end %>
      </div>
    </section>

    <section class="px-4 py-3">
      <h2 class="text-sm font-semibold text-slate-900 mb-1"><%= t("preferences.wheel_title") %></h2>
      <p class="text-xs text-slate-500 mb-3"><%= t("preferences.wheel_help") %></p>
      <div class="flex gap-4 text-sm">
        <% ActorPreferences::WHEEL_PRESETS.keys.each do |preset| %>
          <label class="flex items-center gap-1.5">
            <input type="radio" name="preferences[wheel_preset]" value="<%= preset %>"
                   <%= "checked" if current_actor.pref_wheel_preset == preset %>>
            <span><%= preset %></span>
          </label>
        <% end %>
      </div>
    </section>

    <section class="px-4 py-3">
      <h2 class="text-sm font-semibold text-slate-900 mb-1"><%= t("preferences.sidebar_click_title") %></h2>
      <p class="text-xs text-slate-500 mb-3"><%= t("preferences.sidebar_click_help") %></p>
      <div class="flex flex-col gap-1 text-sm">
        <label class="flex items-center gap-1.5">
          <input type="radio" name="preferences[sidebar_click_mode]" value="navigate"
                 <%= "checked" if current_actor.pref_sidebar_click_mode == "navigate" %>>
          <span><%= t("preferences.sidebar_click_replace_html") %></span>
        </label>
        <label class="flex items-center gap-1.5">
          <input type="radio" name="preferences[sidebar_click_mode]" value="append"
                 <%= "checked" if current_actor.pref_sidebar_click_mode == "append" %>>
          <span><%= t("preferences.sidebar_click_append_html") %></span>
        </label>
      </div>
    </section>

    <%# #435 (Hans, 2026-06-01): Anzahl der zuletzt geoeffneten Themen in der Sidebar. %>
    <section class="px-4 py-3">
      <h2 class="text-sm font-semibold text-slate-900 mb-1"><%= t("preferences.recent_topics_title") %></h2>
      <p class="text-xs text-slate-500 mb-3"><%= t("preferences.recent_topics_help_html") %></p>
      <input type="number" name="preferences[sidebar_recent_topics_count]"
             min="0" max="20" step="1"
             value="<%= current_actor.pref_sidebar_recent_topics_count %>"
             class="w-20 text-sm border border-slate-300 rounded px-2 py-1 focus:outline-none focus:border-emerald-400">
    </section>

    <%# #846 (Hans, 2026-07-06): Sidebar-Layout — welche Eintraege in welchem
        Bereich (Fest oben / Scrollbereich / Ausgeblendet) und in welcher
        Reihenfolge. Drag & Drop zwischen den drei Spalten; die Hidden-Inputs
        werden vom sidebar-layout-editor-Controller synchron gehalten. %>
    <section class="px-4 py-3"
             data-controller="sidebar-layout-editor"
             data-sidebar-layout-editor-default-value="<%= ActorPreferences.default_sidebar_layout.to_json %>"
             data-sidebar-layout-editor-labels-value="<%= sidebar_item_labels.to_json %>"
             data-sidebar-layout-editor-icons-value="<%= sidebar_item_icons_svg.to_json %>">
      <div class="flex items-center justify-between mb-1">
        <h2 class="text-sm font-semibold text-slate-900"><%= t("preferences.sidebar_layout_title") %></h2>
        <button type="button" data-action="sidebar-layout-editor#reset"
                class="text-xs text-slate-500 hover:text-slate-800 underline cursor-pointer">
          <%= t("preferences.sidebar_layout_reset") %>
        </button>
      </div>
      <p class="text-xs text-slate-500 mb-3"><%= t("preferences.sidebar_layout_help") %></p>
      <% layout = current_actor.pref_sidebar_layout %>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        <% [["pinned", t("preferences.sidebar_layout_pinned")],
            ["scroll", t("preferences.sidebar_layout_scroll")],
            ["hidden", t("preferences.sidebar_layout_hidden")]].each do |section, title| %>
          <div>
            <div class="text-[11px] font-semibold uppercase tracking-wider text-slate-500 mb-1"><%= title %></div>
            <ul data-sidebar-layout-editor-target="list" data-section="<%= section %>"
                class="min-h-16 rounded border border-slate-200 bg-slate-50 p-1 flex flex-col gap-1">
              <% layout[section].each do |item_id| %>
                <li data-item-id="<%= item_id %>"
                    class="flex items-center gap-2 px-2 py-1 rounded border border-slate-200 bg-white text-sm cursor-grab select-none">
                  <span class="text-slate-400 shrink-0">⋮⋮</span>
                  <span class="w-4 flex items-center justify-center shrink-0 text-slate-500"><%= icon(sidebar_item_icon(item_id), size: "w-4 h-4") %></span>
                  <span class="truncate"><%= sidebar_item_label(item_id) %></span>
                </li>
              <% end %>
            </ul>
            <input type="hidden" data-sidebar-layout-editor-target="input" data-section="<%= section %>"
                   name="preferences[sidebar_layout][<%= section %>]"
                   value="<%= layout[section].join(",") %>">
          </div>
        <% end %>
      </div>
    </section>

    <%# #709 (Hans): CM6 ist jetzt der Standard-Editor (kein Umschalter mehr;
        die alte Plain-Textarea-Ansicht ist abgeschafft). Per-Request-
        Override für Tests bleibt via ?cm6=0 möglich. %>

    <%# #768 (Hans): explizite Selbst-Identität — verknüpft Dich mit Deiner
        Personen-KI. Daraus zieht der Mail-Sync Deine eigenen Adressen. %>
    <section class="px-4 py-3">
      <h2 class="text-sm font-semibold text-slate-900 mb-1"><%= t("preferences.self_ki_title") %></h2>
      <p class="text-xs text-slate-500 mb-3"><%= t("preferences.self_ki_help") %></p>
      <input type="text" name="preferences[person_ki_title]" list="self-ki-persons"
             value="<%= current_actor.person_ki&.title %>"
             placeholder="<%= t('preferences.self_ki_placeholder') %>"
             class="w-full max-w-md text-sm border border-slate-300 rounded px-2 py-1 focus:outline-none focus:border-emerald-400">
      <datalist id="self-ki-persons">
        <% KnowledgeItem.persons.where(deleted_at: nil).order(Arel.sql("LOWER(title)")).limit(500).pluck(:title).each do |ti| %>
          <option value="<%= ti %>"></option>
        <% end %>
      </datalist>
      <% if current_actor.person_ki %>
        <p class="text-xs text-slate-400 mt-1"><%= t("preferences.self_ki_addresses", n: current_actor.self_email_addresses.size) %></p>
      <% end %>
    </section>

    <div class="px-4 py-3 flex justify-end">
      <%= f.submit t("preferences.save"),
            class: "px-3 py-1 rounded bg-emerald-600 text-white text-sm hover:bg-emerald-700 cursor-pointer" %>
    </div>
  <% end %>

<%# #552/#559 (Hans): an/abw√§hlbare ID-Felder der Aussteller‚ÜîEmpf√§nger-
    Beziehung ‚Äî seit #926 geteilt (local: printable). #559: gleiches
    3-Spalten-Raster wie die √ºbrigen Infoblock-Felder ‚Äî Checkbox in Spalte 1,
    ID-Bezeichnung in Spalte 2, Wert in Spalte 3. Die Zuordnung
    ("Hans Siem Groth ‚Üí ‚Ä¶") steht als Unterzeile linksb√ºndig mit dem Key.
    Eigener Wrapper mit stabiler id f√ºr #552-Auto-Refresh. %>
<% printable = local_assigns.fetch(:printable) %>
<% cands = printable.identifier_candidates %>
<div id="<%= printable.model_name.param_key %>_id_candidates_<%= printable.id %>">
  <% if cands.any? %>
    <%= form_with url: polymorphic_path([:select_identifiers, printable]), method: :patch, local: false do %>
      <div class="grid grid-cols-[1.25rem_7rem_1fr_auto] gap-x-2 gap-y-1 items-start">
        <% cands.each do |idr| %>
          <input type="checkbox" name="identifier_ids[]" value="<%= idr.id %>"
                 <%= "checked" if printable.shown_identifier_ids.include?(idr.id) %>
                 onchange="this.form.requestSubmit()" class="rounded border-slate-300 mt-1 cursor-pointer">
          <span class="text-slate-500 mt-0.5"><%= idr.label %></span>
          <span class="font-mono min-w-0 mt-0.5"><%= idr.value %></span>
          <span></span>
          <% if idr.knowledge_item || idr.counterparty %>
            <%# Unterzeile: beginnt in Spalte 2 (Key), spannt bis zum Rand. %>
            <span class="text-slate-400 text-[11px]" style="grid-column: 2 / -1;"><%= idr.knowledge_item&.title %><%= " ‚Üí #{idr.counterparty.title}" if idr.counterparty %></span>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>

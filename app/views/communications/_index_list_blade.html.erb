<%# #163 Phase 6c (Communications): list:communications-Blade fuer die
    /communications-Stack-Seite. Toolbar (Sort/Filter, Klassifikator-
    Button) im sticky Header, Liste der Kommunikationen.

    Datenquelle: @communications + @unclassified_count + @classifier_available
    (aus CommunicationsController#index). %>
<% stack_id = "list:communications" %>
<%# #1018 (Hans, 2026-07-16): bulk-select auf der Card — umschliesst
    Toggle (Header), Row-Checkboxen und die Apply-Leiste im Frame. %>
<article id="stack_card_<%= stack_id %>"
         data-uuid="<%= stack_id %>"
         data-controller="bulk-select"
         class="stack-card shrink-0 relative
                w-[38rem] max-w-[calc(100vw-3rem)]
                bg-white border-l border-slate-200 first:border-l-0
                flex">

  <%= render "shared/list_blade_spine",
        title: t("communications.index_title"),
        icon_html: icon("communications"),
        label: t("communications.index_title") %>

  <div class="flex-1 min-w-0 min-h-0 overflow-y-auto">
    <%# #558: Sortieren/Filtern in-place in diesem Frame (Stack bleibt). %>
    <turbo-frame id="communications_list_frame" class="contents">
    <header class="sticky top-0 z-20 bg-white/95 backdrop-blur border-b border-slate-200 px-3 py-2 flex flex-wrap items-center gap-2">
      <h1 class="font-semibold text-sm"><%= t("communications.index_title") %></h1>

      <% if @unclassified_count > 0 %>
        <%= button_to classify_all_communications_path,
              method: :post,
              form: { class: "inline m-0 p-0",
                      data: { turbo_confirm: t("communications.classify_confirm", count: @unclassified_count) } },
              disabled: !@classifier_available,
              title: (@classifier_available ? nil : t("communications.ollama_unavailable")),
              class: "text-xs rounded px-2 py-1 #{@classifier_available ? 'bg-emerald-600 text-white hover:bg-emerald-700' : 'bg-slate-200 text-slate-500 cursor-not-allowed'}" do %>
          🧠 <%= t("communications.classify", count: @unclassified_count) %>
        <% end %>
      <% elsif !@classifier_available %>
        <span class="text-xs text-amber-700" title="<%= t("communications.setup_hint") %>">
          <%= t("communications.classifier_off") %>
        </span>
      <% end %>

      <span class="ml-auto flex items-center gap-1">
        <%# #1018 (Hans, 2026-07-16): Mehrfachauswahl-Modus (wie bei Aufgaben). %>
        <button type="button" data-action="bulk-select#toggleMode"
                title="<%= t("shared.bulk.multi_select") %>"
                class="inline-flex items-center justify-center p-1 rounded border border-slate-200 text-slate-500 hover:bg-slate-100 hover:text-slate-900 cursor-pointer">
          <%= icon "check", size: "w-3.5 h-3.5" %>
        </button>
        <%# #1005 (Hans): Card an Dashboard-Stack anhängen — in allen Card-Köpfen. %>
        <%= render "shared/append_dashboard_button", size: "w-4 h-4" %>
        <%= render "shared/list_toolbar",
              path:           communications_path,
              frame:          "communications_list_frame",
              sort_options:   [[t("communications.sort_date"), :sent_at],
                               [t("communications.sort_sender"), :sender],
                               [t("communications.sort_subject"), :subject]],
              filter_fields:  [
                { name: :q,         type: :text,   label: t("communications.search_label"),
                  placeholder: t("communications.search_placeholder") },
                { name: :direction, type: :select, label: t("communications.direction_label"),
                  options: [[t("communications.all_directions"), ""],
                            [t("communications.direction.inbound"),  "inbound"],
                            [t("communications.direction.outbound"), "outbound"]] }
              ],
              current_sort:   @sort,
              current_dir:    @dir,
              filter_values:  { q: params[:q], direction: params[:direction] }.compact_blank,
              storage_key:    "communications" %>
      </span>
    </header>

    <section data-controller="active-row">
      <% if @communications.empty? %>
        <p class="px-4 py-3 text-slate-500"><%= t("dashboard.no_communications") %></p>
      <% else %>
        <ul class="divide-y divide-slate-100">
          <% @communications.each do |c| %>
            <%= render "communications/row", comm: c,
                  blade_kind: "communication", blade_id: c.id %>
          <% end %>
        </ul>
      <% end %>
    </section>
    <%# #1018: Bulk-Apply-Leiste (Thema zuordnen / Löschen). %>
    <div class="px-3 pb-3">
      <%= render "communications/bulk_select_bar", key: "communications", topic: nil %>
    </div>
    </turbo-frame>
  </div>
</article>

<%# #533 1d (Hans, 2026-06-07): wiederverwendbare Zeitbuchungs-Liste.
    Locals: entries (Array), optional show_subject (Bool, default true). %>
<%
  entries = local_assigns[:entries] || []
  show_subject = local_assigns.fetch(:show_subject, true)
  total = entries.sum(&:duration_minutes)
%>
<% if entries.any? %>
  <ul class="divide-y divide-slate-100 text-xs">
    <% entries.each do |e| %>
      <li class="flex items-center gap-2 py-1 cursor-pointer hover:bg-slate-50 -mx-1 px-1 rounded"
          data-action="click->blade-stack#openTimeEntry"
          data-time-entry-id="<%= e.id %>"
          title="<%= t("shared.time_list.open_entry") %>">
        <span class="w-1.5 h-1.5 rounded-full shrink-0
                     <%= e.running? ? 'bg-emerald-500' : (e.paused? ? 'bg-amber-400' : 'bg-slate-300') %>"
              title="<%= e.status %>"></span>
        <span class="font-mono tabular-nums text-slate-700 w-16 shrink-0"><%= format_minutes(e.duration_minutes) %></span>
        <%# #533 (Hans-Wunsch): Start- und Endzeit mit angeben. %>
        <span class="text-slate-400 shrink-0 whitespace-nowrap tabular-nums">
          <%= e.started_at&.strftime("%d.%m. %H:%M") %>–<%= e.ended_at ? e.ended_at.strftime("%H:%M") : (e.running? ? t("shared.time_list.running") : t("shared.time_list.paused")) %>
        </span>
        <span class="flex-1 min-w-0 truncate text-slate-600">
          <% if show_subject && (lbl = time_entry_subject_label(e)) %><%= lbl %><% end %>
          <% if e.note.present? %><span class="text-slate-400">· <%= e.note %></span><% end %>
          <% if e.topic %><span class="text-slate-400">· <%= e.topic.name %></span><% end %>
        </span>
        <% if e.billable %><span class="text-emerald-600 shrink-0" title="<%= t("shared.time_list.billable") %>">€</span><% end %>
      </li>
    <% end %>
  </ul>
  <div class="mt-1 text-xs text-slate-700 font-medium"><%= t("shared.time_list.total") %> <%= format_minutes(total) %></div>
<% else %>
  <p class="text-xs text-slate-400"><%= t("shared.time_list.empty") %></p>
<% end %>

<% content_for :title, "#{t("portal.dokumente.title")} — #{portal_topic.name}" %>
<h1><%= t("portal.dokumente.title") %></h1>
<% if @artifacts.empty? %>
  <p class="muted"><%= t("portal.dokumente.empty") %></p>
<% end %>
<% @artifacts.each do |a| %>
  <div class="card row">
    <a href="<%= portal_artifact_href(a) %>"><%= a.printable.display_name.presence || t("portal.dokumente.document_fallback", id: a.printable_id) %><%= " · #{t("portal.dokumente.signed")}" if a.signed %></a>
    <span class="muted"><%= l a.created_at.to_date, format: :long %> · PDF</span>
  </div>
<% end %>

<%# #546 (Hans): Affiliations einer Person (zu Organisationen). Chevron +
    getrennte Anzeige/Edit + Add/Edit in der Titelzeile + Lösch-Rückfrage.
    Speichert via PATCH ans KI (PersonOrgSync). Nur für person-KIs. %>
<% return unless item.item_type == "person" %>
<% affs = item.affiliations_as_person.includes(:organization).ordered %>
<%# #681 (Hans): leere Sektion standardmäßig eingeklappt. %>
<% collapsed = affs.empty? %>
<% row = "grid grid-cols-[1fr_1fr_5rem_5rem_auto_auto] gap-1 px-3 py-1.5 items-center text-[13px] border-b border-slate-50" %>
<section data-controller="disclosure section-edit rows-editor"
         data-disclosure-storage-key-value="knowledge.<%= item.uuid %>.affiliations"
         class="border border-slate-200 rounded">
  <header class="px-3 py-1.5 text-xs text-slate-600 border-b border-slate-100 font-medium flex items-center gap-2 bg-slate-50 rounded-t">
    <button type="button" data-action="click->disclosure#toggle"
            class="flex items-center gap-2 flex-1 text-left bg-transparent border-0 p-0 cursor-pointer text-slate-600">
      <span data-disclosure-target="icon" class="inline-block transition-transform <%= 'rotate-90' unless collapsed %> text-slate-400 [&_svg]:w-3.5 [&_svg]:h-3.5"><%= icon "chevron_right" %></span>
      <span><%= t("knowledge.editors.affiliations.title") %> · <%= affs.size %></span>
    </button>
    <button type="button" data-action="click->section-edit#edit" title="<%= t("actions.edit") %>"
            class="p-0.5 text-slate-400 hover:text-slate-700 [&_svg]:w-3.5 [&_svg]:h-3.5"><%= icon "pencil" %></button>
    <button type="button" data-action="click->section-edit#edit click->rows-editor#add"
            title="<%= t("knowledge.editors.affiliations.add") %>" class="p-0.5 text-emerald-600 hover:text-emerald-800 [&_svg]:w-4 [&_svg]:h-4"><%= icon "plus_circle" %></button>
  </header>

  <div data-disclosure-target="content" class="<%= 'hidden' if collapsed %>">
    <%# ── Anzeige ── %>
    <div data-section-edit-target="display" class="px-3 py-2 text-[13px] space-y-1">
      <% if affs.any? %>
        <% affs.each do |aff| %>
          <div><% if aff.primary %><span class="text-amber-500">★</span> <% end %><span class="text-slate-500"><%= aff.role.presence || "—" %>:</span> <%= aff.organization.title %><% if aff.start_at || aff.end_at %> <span class="text-slate-400 text-xs"><%= aff.start_at&.year %><%= "–#{aff.end_at&.year}" if aff.end_at %></span><% end %></div>
        <% end %>
      <% else %>
        <p class="text-slate-400 italic"><%= t("knowledge.editors.affiliations.empty") %></p>
      <% end %>
    </div>

    <%# ── Edit ── %>
    <div data-section-edit-target="edit" hidden>
      <%= form_with url: knowledge_item_path(item.uuid), method: :patch, local: false do |f| %>
        <% if in_stack %><%= f.hidden_field :in_stack, value: "1" %><% end %>
        <template data-rows-editor-target="template">
          <div data-row class="<%= row %>">
            <input type="text" name="affiliations[][org]" placeholder="<%= t("knowledge.editors.affiliations.org_placeholder") %>" list="org-suggestions-<%= item.uuid %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
            <input type="text" name="affiliations[][role]" placeholder="<%= t("knowledge.editors.affiliations.role_placeholder") %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
            <input type="date" name="affiliations[][from]" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
            <input type="date" name="affiliations[][to]" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
            <label class="flex items-center gap-1 text-xs text-slate-500" title="<%= t("knowledge.editors.affiliations.primary") %>"><input type="checkbox" name="affiliations[][primary]" value="1"> ★</label>
            <button type="button" data-action="click->rows-editor#removeConfirm" class="p-1 text-slate-400 hover:text-rose-600">×</button>
          </div>
        </template>

        <div data-rows-editor-target="rows">
          <% affs.each do |aff| %>
            <div data-row data-existing="true" class="<%= row %>">
              <input type="text" name="affiliations[][org]" value="<%= aff.organization.title %>" list="org-suggestions-<%= item.uuid %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
              <input type="text" name="affiliations[][role]" value="<%= aff.role %>" placeholder="<%= t("knowledge.editors.affiliations.role_placeholder") %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
              <input type="date" name="affiliations[][from]" value="<%= aff.start_at %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
              <input type="date" name="affiliations[][to]" value="<%= aff.end_at %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
              <label class="flex items-center gap-1 text-xs text-slate-500"><input type="checkbox" name="affiliations[][primary]" value="1" <%= "checked" if aff.primary %>> ★</label>
              <button type="button" data-action="click->rows-editor#removeConfirm" class="p-1 text-slate-400 hover:text-rose-600">×</button>
            </div>
          <% end %>
        </div>

        <datalist id="org-suggestions-<%= item.uuid %>">
          <% org_titles_for_datalist.each do |t| %><% next if t == item.title %><option value="<%= t %>"></option><% end %>
        </datalist>

        <div class="flex items-center gap-2 px-3 py-2 border-t border-slate-100 bg-slate-50/50">
          <button type="button" data-action="click->section-edit#cancel" class="text-xs px-2 py-0.5 rounded text-slate-600 hover:bg-slate-100"><%= t("actions.cancel") %></button>
          <button type="submit" class="ml-auto text-xs px-3 py-0.5 rounded bg-emerald-600 text-white hover:bg-emerald-700 cursor-pointer"><%= t("actions.save") %></button>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# #541 (Hans, 2026-06-09): Aussteller-Pflichtangaben einer Rechnung (read-only,
    kommen aus den IDs des Aussteller-KI): Steuernummer/USt-IdNr (§14 UStG) +
    optional IBAN für den Zahlungsblock. Warnt, wenn Pflichtangaben fehlen. %>
<% document = local_assigns.fetch(:document) %>
<section id="document_issuer_compliance_<%= document.id %>" class="space-y-1 text-[12px] pt-2 border-t border-slate-100">
  <div class="text-slate-500 font-medium"><%= t("documents.compliance.issuer_details") %></div>
  <% if document.issuer %>
    <% if document.issuer_tax_ids.any? %>
      <% document.issuer_tax_ids.each do |label, value| %>
        <div class="text-slate-600"><%= label %>: <span class="font-mono"><%= value %></span></div>
      <% end %>
    <% else %>
      <div class="text-amber-700">⚠ <%= t("documents.compliance.no_tax_id_warning") %></div>
    <% end %>
    <% if document.issuer_iban %>
      <div class="text-slate-600">IBAN: <span class="font-mono"><%= document.issuer_iban %></span><%= " · BIC #{document.issuer_bic}" if document.issuer_bic %></div>
    <% else %>
      <div class="text-slate-400"><%= t("documents.compliance.no_iban_note") %></div>
    <% end %>
  <% else %>
    <div class="text-slate-400"><%= t("documents.compliance.no_issuer_note") %></div>
  <% end %>
</section>

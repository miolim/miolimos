<%# #541 (Hans, 2026-06-09): Rechnungspositionen als LISTE. Jede Position
    öffnet ihr eigenes Detail-Blade (Felder + Zeit-Zuordnung). "+ Position"
    legt eine leere Position an. Bei final read-only. Ist der Aussteller
    USt-befreit, wird keine USt ausgewiesen.
    Wrapper mit stabiler id für den Turbo-Refresh nach Änderungen. %>
<% invoice = local_assigns.fetch(:invoice) %>
<% exempt = invoice.vat_exempt? %>
<% lines  = invoice.invoice_lines.ordered %>
<section id="invoice_invoice_lines_<%= invoice.id %>" class="space-y-2 text-[13px] pt-3 mt-3 border-t border-slate-300">
  <div class="flex items-center gap-2">
    <span class="text-[15px] font-semibold text-slate-600"><%= t("documents.invoice.lines_heading") %></span>
    <% unless invoice.locked? %>
      <%= button_to add_invoice_line_invoice_path(invoice), method: :post,
            form: { class: "ml-auto inline", data: { turbo_stream: true } },
            class: "text-xs px-2 py-0.5 rounded text-emerald-700 hover:bg-emerald-50 cursor-pointer" do %><%= t("documents.invoice.add_position") %><% end %>
    <% end %>
  </div>

  <% if lines.any? %>
    <%# #541 (Hans): inline editierbar (Beschreibung/Menge/Preis/USt) UND je
        Zeile ein › zum Öffnen des Detail-Blades (Zeit-Zuordnung). Zeit-basierte
        Menge ist read-only (kommt aus den Zeiten). %>
    <% cols = exempt ? "grid grid-cols-[1fr_3.5rem_4.5rem_4.5rem_auto] gap-1 items-center"
                     : "grid grid-cols-[1fr_3.5rem_4.5rem_3rem_4.5rem_auto] gap-1 items-center" %>
    <div class="<%= cols %> text-[11px] text-slate-400 px-1">
      <span><%= t("documents.invoice.description") %></span><span><%= t("documents.invoice.quantity") %></span><span><%= t("documents.invoice.price") %></span><% unless exempt %><span><%= t("documents.invoice.vat_pct") %></span><% end %><span class="text-right"><%= t("documents.invoice.net") %></span><span></span>
    </div>
    <div class="divide-y divide-slate-50 border border-slate-100 rounded">
      <% lines.each do |line| %>
        <% unless invoice.locked? %>
          <%= form_with url: invoice_line_path(line), method: :patch, local: false, class: "#{cols} px-1 py-1" do %>
            <input type="text" name="description" value="<%= line.description %>" placeholder="<%= t("documents.invoice.new_position_placeholder") %>"
                   onblur="if (this.value !== this.defaultValue) this.form.requestSubmit()"
                   class="border border-slate-200 rounded px-1 py-0.5 text-xs">
            <% if line.time_based? %>
              <input type="text" value="<%= number_with_precision(line.quantity, precision: 2, separator: ',', delimiter: '', strip_insignificant_zeros: true) %>" readonly title="<%= t("documents.invoice.from_times") %>"
                     class="border border-slate-100 rounded px-1 py-0.5 text-xs text-right tabular-nums bg-slate-50 text-slate-500">
            <% else %>
              <input type="text" inputmode="decimal" name="quantity" value="<%= number_with_precision(line.quantity, precision: 2, separator: ',', delimiter: '', strip_insignificant_zeros: true) %>"
                     onchange="this.form.requestSubmit()" class="border border-slate-200 rounded px-1 py-0.5 text-xs text-right tabular-nums">
            <% end %>
            <input type="text" inputmode="decimal" name="unit_price" value="<%= number_with_precision(line.unit_price, precision: 2, separator: ',', delimiter: '') %>"
                   onchange="this.form.requestSubmit()" class="border border-slate-200 rounded px-1 py-0.5 text-xs text-right tabular-nums">
            <% unless exempt %>
              <input type="text" inputmode="decimal" name="tax_rate" value="<%= number_with_precision(line.tax_rate, precision: 1, separator: ',', delimiter: '', strip_insignificant_zeros: true) %>"
                     onchange="this.form.requestSubmit()" class="border border-slate-200 rounded px-1 py-0.5 text-xs text-right tabular-nums">
            <% end %>
            <span class="tabular-nums text-right text-xs"><%= document_euro(line.net) %></span>
            <button type="button" title="<%= t("documents.invoice.open_position") %>"
                    data-controller="blade-link" data-blade-link-kind-value="invoice_line"
                    data-blade-link-id-value="<%= line.id %>" data-action="click->blade-link#append"
                    class="shrink-0 text-slate-300 hover:text-sky-600 bg-transparent border-0 cursor-pointer px-1">›</button>
          <% end %>
        <% else %>
          <div class="<%= cols %> px-1 py-1 text-xs">
            <span class="truncate"><%= line.description.presence || "—" %></span>
            <span class="text-right tabular-nums"><%= number_with_precision(line.quantity, precision: 2, separator: ',', delimiter: '', strip_insignificant_zeros: true) %></span>
            <span class="text-right tabular-nums"><%= document_euro(line.unit_price) %></span>
            <% unless exempt %><span class="text-right tabular-nums"><%= number_with_precision(line.tax_rate, precision: 1, separator: ',', delimiter: '', strip_insignificant_zeros: true) %></span><% end %>
            <span class="text-right tabular-nums"><%= document_euro(line.net) %></span><span></span>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p class="text-slate-400 italic"><%= t("documents.invoice.no_positions_yet") %></p>
  <% end %>

  <%# — Summen — %>
  <% if lines.any? %>
    <div class="pt-2 mt-2 border-t border-slate-300 space-y-0.5">
      <div class="flex justify-between"><span class="text-slate-500"><%= t("documents.invoice.net_amount") %></span><span class="tabular-nums"><%= document_euro(invoice.net_total) %></span></div>
      <% invoice.tax_breakdown.each do |g| %>
        <div class="flex justify-between text-slate-500"><span><%= t("documents.invoice.plus_vat", rate: number_with_precision(g[:rate], precision: 1, separator: ",", delimiter: "", strip_insignificant_zeros: true)) %></span><span class="tabular-nums"><%= document_euro(g[:tax]) %></span></div>
      <% end %>
      <div class="flex justify-between font-semibold"><span><%= t("documents.invoice.total_amount") %></span><span class="tabular-nums"><%= document_euro(invoice.gross_total) %></span></div>
      <% if exempt %>
        <div class="text-slate-500 text-[12px] italic pt-1"><%= t("documents.invoice.vat_exempt_note") %></div>
      <% end %>
    </div>
  <% end %>
</section>

<%# #532/#546 (Hans): strukturierter Adress-Editor am Person/Org-KI. Chevron +
    getrennte Anzeige/Edit + Add/Edit in der Titelzeile + Lösch-Rückfrage.
    DB-direkt. Locals: item, in_stack %>
<% return unless item.item_type.in?(%w[person organization]) %>
<% addrs = item.postal_addresses.ordered %>
<%# #681 (Hans): leere Sektion standardmäßig eingeklappt. %>
<% collapsed = addrs.empty? %>
<section id="postal_addresses_section_<%= item.uuid %>"
         data-controller="disclosure section-edit rows-editor"
         data-disclosure-storage-key-value="knowledge.<%= item.uuid %>.address"
         class="border border-slate-200 rounded">
  <header class="px-3 py-1.5 text-xs text-slate-600 border-b border-slate-100 font-medium flex items-center gap-2 bg-slate-50 rounded-t">
    <button type="button" data-action="click->disclosure#toggle"
            class="flex items-center gap-2 flex-1 text-left bg-transparent border-0 p-0 cursor-pointer text-slate-600">
      <span data-disclosure-target="icon" class="inline-block transition-transform <%= 'rotate-90' unless collapsed %> text-slate-400 [&_svg]:w-3.5 [&_svg]:h-3.5"><%= icon "chevron_right" %></span>
      <span><%= t("knowledge.editors.address.title") %> · <%= addrs.size %></span>
    </button>
    <button type="button" data-action="click->section-edit#edit" title="<%= t("actions.edit") %>"
            class="p-0.5 text-slate-400 hover:text-slate-700 [&_svg]:w-3.5 [&_svg]:h-3.5"><%= icon "pencil" %></button>
    <button type="button" data-action="click->section-edit#edit click->rows-editor#add"
            title="<%= t("knowledge.editors.address.add") %>" class="p-0.5 text-emerald-600 hover:text-emerald-800 [&_svg]:w-4 [&_svg]:h-4"><%= icon "plus_circle" %></button>
  </header>

  <div data-disclosure-target="content" class="<%= 'hidden' if collapsed %>">
    <%# ── Anzeige ── %>
    <div data-section-edit-target="display" class="px-3 py-2 text-[13px] space-y-1.5">
      <% if addrs.any? %>
        <% addrs.each do |a| %>
          <%# #723 (Hans): Action-Icon — Adresse in die Zwischenablage kopieren. %>
          <div class="flex items-start gap-1.5">
            <span class="min-w-0"><%= a.lines.join(", ") %><% if a.post? %> <span class="text-[11px] text-slate-400">· <%= t("knowledge.editors.address.postal") %></span><% end %><% if a.billing %> <span class="text-[11px] text-slate-400">· <%= t("knowledge.editors.address.billing") %></span><% end %></span>
            <% if a.lines.any? %>
              <button type="button" data-controller="copy-clipboard" data-action="click->copy-clipboard#copy"
                      data-copy-clipboard-content-value="<%= a.lines.join(", ") %>" data-copy-clipboard-toast-value="<%= t("knowledge.editors.address.copied") %>"
                      title="<%= t("knowledge.editors.address.copy") %>" aria-label="<%= t("knowledge.editors.address.copy") %>"
                      class="shrink-0 mt-0.5 p-0.5 rounded text-slate-400 hover:text-slate-700 hover:bg-slate-100 cursor-pointer [&_svg]:w-3.5 [&_svg]:h-3.5"><%= icon "copy" %></button>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <p class="text-slate-400 italic"><%= t("knowledge.editors.address.empty") %></p>
      <% end %>
    </div>

    <%# ── Edit ── %>
    <div data-section-edit-target="edit" hidden>
      <%= form_with url: addresses_knowledge_item_path(item.uuid), method: :patch, local: false do |f| %>
        <% if in_stack %><%= f.hidden_field :in_stack, value: "1" %><% end %>
        <%# #546: × in eigener rechter Spalte, vertikal zentriert neben dem
            ganzen Adressblock — nicht mehr unter dem Straßenfeld. %>
        <template data-rows-editor-target="template">
          <div data-row class="px-3 py-1.5 border-b border-slate-50 grid grid-cols-[1fr_auto] gap-2 items-center">
            <div class="space-y-1 min-w-0">
              <input type="text" name="addresses[][line1]" placeholder="<%= t("knowledge.editors.address.street_placeholder") %>" class="w-full border border-slate-200 rounded px-1 py-0.5 text-xs">
              <input type="text" name="addresses[][line2]" placeholder="<%= t("knowledge.editors.address.line2_placeholder") %>" class="w-full border border-slate-200 rounded px-1 py-0.5 text-xs">
              <div class="grid grid-cols-[4.5rem_1fr_4.5rem] gap-1">
                <input type="text" name="addresses[][postal_code]" placeholder="<%= t("knowledge.editors.address.postal_code_placeholder") %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
                <input type="text" name="addresses[][city]" placeholder="<%= t("knowledge.editors.address.city_placeholder") %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
                <input type="text" name="addresses[][country]" placeholder="<%= t("knowledge.editors.address.country_placeholder") %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
              </div>
              <div class="flex items-center gap-2">
                <select name="addresses[][kind]" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
                  <option value="liegenschaft"><%= t("knowledge.editors.address.kind_property") %></option>
                  <option value="post"><%= t("knowledge.editors.address.kind_postal") %></option>
                </select>
                <label class="flex items-center gap-1 text-xs text-slate-500"><input type="checkbox" name="addresses[][billing]" value="1"> <%= t("knowledge.editors.address.billing") %></label>
              </div>
            </div>
            <button type="button" data-action="click->rows-editor#removeConfirm" class="p-1 text-slate-400 hover:text-rose-600">×</button>
          </div>
        </template>

        <div data-rows-editor-target="rows">
          <% addrs.each do |a| %>
            <div data-row data-existing="true" class="px-3 py-1.5 border-b border-slate-50 grid grid-cols-[1fr_auto] gap-2 items-center">
              <div class="space-y-1 min-w-0">
                <input type="hidden" name="addresses[][id]" value="<%= a.id %>">
                <input type="text" name="addresses[][line1]" value="<%= a.line1 %>" placeholder="<%= t("knowledge.editors.address.street_placeholder") %>" class="w-full border border-slate-200 rounded px-1 py-0.5 text-xs">
                <input type="text" name="addresses[][line2]" value="<%= a.line2 %>" placeholder="<%= t("knowledge.editors.address.line2_placeholder") %>" class="w-full border border-slate-200 rounded px-1 py-0.5 text-xs">
                <div class="grid grid-cols-[4.5rem_1fr_4.5rem] gap-1">
                  <input type="text" name="addresses[][postal_code]" value="<%= a.postal_code %>" placeholder="<%= t("knowledge.editors.address.postal_code_placeholder") %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
                  <input type="text" name="addresses[][city]" value="<%= a.city %>" placeholder="<%= t("knowledge.editors.address.city_placeholder") %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
                  <input type="text" name="addresses[][country]" value="<%= a.country %>" placeholder="<%= t("knowledge.editors.address.country_placeholder") %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
                </div>
                <div class="flex items-center gap-2">
                  <select name="addresses[][kind]" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
                    <option value="liegenschaft" <%= "selected" if a.liegenschaft? %>><%= t("knowledge.editors.address.kind_property") %></option>
                    <option value="post" <%= "selected" if a.post? %>><%= t("knowledge.editors.address.kind_postal") %></option>
                  </select>
                  <label class="flex items-center gap-1 text-xs text-slate-500"><input type="checkbox" name="addresses[][billing]" value="1" <%= "checked" if a.billing %>> <%= t("knowledge.editors.address.billing") %></label>
                </div>
              </div>
              <button type="button" data-action="click->rows-editor#removeConfirm" class="p-1 text-slate-400 hover:text-rose-600">×</button>
            </div>
          <% end %>
        </div>

        <div class="flex items-center gap-2 px-3 py-2 border-t border-slate-100 bg-slate-50/50">
          <button type="button" data-action="click->section-edit#cancel" class="text-xs px-2 py-0.5 rounded text-slate-600 hover:bg-slate-100"><%= t("actions.cancel") %></button>
          <button type="submit" class="ml-auto text-xs px-3 py-0.5 rounded bg-emerald-600 text-white hover:bg-emerald-700 cursor-pointer"><%= t("actions.save") %></button>
        </div>
      <% end %>
    </div>
  </div>
</section>

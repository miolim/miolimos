<%# #532 Phase 2: Briefkopf aus dem gewählten Aussteller (issuer-KI). Ohne
    markierten Aussteller bleibt ein Platzhalter stehen, damit die Werkbank
    auch ohne Stammdaten rendert. Genutzt von _sample_invoice/_sample_nda. %>
<% issuer = local_assigns.fetch(:issuer, @issuer) %>
<header class="doc-letterhead">
  <div class="doc-logo"><%= issuer&.title.presence || "miolim" %></div>
  <div class="doc-sender">
    <% if issuer %>
      <%= document_sender_html(issuer) %>
    <% else %>
      <span style="color:#9ca3af;"><%= t("documents.letter.no_issuer_html") %></span>
    <% end %>
  </div>
</header>

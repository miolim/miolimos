<% content_for :title, t("awaitings.index_title") %>

<%# #163 Phase 6c (Awaitings): /awaitings ist eine Blade-Stack-Seite.
    Default ist `?stack=list:awaitings`; Klick auf einen Wartepunkt
    appendet die Detail-Blade rechts, die Listen-Blade collapsed
    automatisch. Vollaufruf von /awaitings/:id leitet auf
    /awaitings?stack=list:awaitings,awaiting:<id> um. %>
<div data-controller="blade-stack"
     data-blade-stack-history-storage-key-value="awaitings.stack.history"
     class="flex flex-col h-[calc(100dvh-5rem)]">
  <main id="blade_stack_container" data-blade-stack-target="container"
        class="flex-1 flex overflow-x-auto scroll-smooth
               bg-slate-50 rounded border border-slate-200 min-h-0">
    <% @initial_stack_items.each do |stack_item| %>
      <% if stack_item.kind == :list && stack_item.id == "awaitings" %>
        <%= render "awaitings/index_list_blade" %>
      <% else %>
        <% locals = stack_item.partial_locals %>
        <% locals = locals.merge(body_html: @initial_stack_bodies[stack_item.record.uuid]) if stack_item.kind == :ki %>
        <%= render stack_item.partial, **locals %>
      <% end %>
    <% end %>
  </main>
</div>

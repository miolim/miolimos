<% content_for :title, t("communications.index_title") %>

<%# #163 Phase 6c (Communications): /communications ist eine Blade-
    Stack-Seite. Default `?stack=list:communications`. Klick auf eine
    Zeile appendet das Detail-Blade rechts, die Liste collapsed auf
    den Spine. Vollaufruf /communications/:id redirected entsprechend. %>
<div data-controller="blade-stack"
     data-blade-stack-history-storage-key-value="communications.stack.history"
     <%= raw blade_stack_pref_attrs %>
     class="flex flex-col h-[calc(100dvh-5rem)]">
  <main id="blade_stack_container" data-blade-stack-target="container"
        class="flex-1 flex overflow-x-auto scroll-smooth
               bg-slate-50 rounded border border-slate-200 min-h-0">
    <% @initial_stack_items.each do |stack_item| %>
      <% if stack_item.kind == :list && stack_item.id == "communications" %>
        <%= render "communications/index_list_blade" %>
      <% else %>
        <% locals = stack_item.partial_locals %>
        <% locals = locals.merge(body_html: @initial_stack_bodies[stack_item.record.uuid]) if stack_item.kind == :ki %>
        <%= render stack_item.partial, **locals %>
      <% end %>
    <% end %>
  </main>
</div>

<%# #532 (Hans, 2026-06-08): Detail-Blade eines Anschreibens. Meta-Felder +
    Picker für die Verknüpfungen (Aussteller/Empfänger/Topic/Body-KI), inline
    auto-save (PATCH, Turbo-Stream ersetzt den Felder-Block). Vorschau/PDF
    rendern den Record über das DIN-5008-Theme. %>
<% labels = DocumentsController::KIND_LABELS %>
<%# #559 (Hans): Benennung (Betreff) im Header und — hinter der Art — im Spine. %>
<% name  = document.display_name %>
<% spine = name ? "#{labels[document.kind]} · #{name}" : labels[document.kind] %>
<article id="stack_card_document:<%= document.id %>"
         data-uuid="document:<%= document.id %>"
         class="stack-card shrink-0 relative w-[26rem] max-w-[calc(100vw-3rem)]
                bg-white border-l border-slate-200 first:border-l-0 flex">

  <%= render "shared/blade_spine", stack_id: "document:#{document.id}", title: spine,
        icon_html: icon("file_text"), label: spine, topics: [document.topic] %>

  <div class="flex-1 min-w-0 min-h-0 overflow-y-auto p-3 space-y-3">
    <%# #868 (Hans): Ausgabe-Aktionen (früher als Text-Fußzeile unten) jetzt
        oben in der gemeinsamen Card-Werkzeugleiste, als Icons. Darunter die
        Titelzeile mit Art-Badge + Name. %>
    <%= render "shared/blade_toolbar", uuid: "document:#{document.id}",
          toolbar_class: "-mx-3 -mt-3 px-3 pt-2 pb-2 bg-white",
          duplicate: false, entity_actions: capture { %>
      <%# Vorschau (gerendertes Dokument im neuen Tab). %>
      <%= link_to document_path(document), target: "_blank", rel: "noopener",
            title: t("documents.show.preview"), "aria-label": t("documents.show.preview"),
            class: "p-1 rounded hover:bg-slate-100 hover:text-slate-900 shrink-0" do %>
        <%= icon "external_link" %>
      <% end %>
      <%# PDF. %>
      <%= link_to rendered_pdf_document_path(document), target: "_blank", rel: "noopener",
            title: t("documents.show.pdf"), "aria-label": t("documents.show.pdf"),
            class: "p-1 rounded hover:bg-slate-100 hover:text-slate-900 shrink-0" do %>
        <%= icon "file_pdf" %>
      <% end %>
      <%# #547: AES-signiertes PDF — nur wenn das Signier-Setup vorhanden ist. %>
      <% if DocumentSigner.available? %>
        <%= link_to signed_pdf_document_path(document), target: "_blank", rel: "noopener",
              title: t("documents.list.signed_pdf_title"), "aria-label": t("documents.list.signed_pdf"),
              class: "p-1 rounded hover:bg-slate-100 hover:text-slate-900 shrink-0" do %>
          <%= icon "file_check" %>
        <% end %>
      <% end %>
      <%# #787: Dokument löschen (Soft-Delete → Papierkorb). %>
      <%= button_to document_path(document), method: :delete,
            form: { class: "inline m-0 p-0", data: { turbo_confirm: t("documents.trash.confirm") } },
            title: t("documents.trash.delete_title"), "aria-label": t("documents.trash.delete"),
            class: "p-1 rounded hover:bg-rose-50 hover:text-rose-700 bg-transparent border-0 cursor-pointer shrink-0" do %>
        <%= icon "trash" %>
      <% end %>
    <% } %>

    <div class="flex items-center gap-2">
      <span class="shrink-0 text-[10px] uppercase tracking-wide px-1.5 py-0.5 rounded bg-slate-100 text-slate-600"><%= labels[document.kind] %></span>
      <span class="font-semibold text-sm truncate"><%= name || t("documents.list.unnamed") %></span>
    </div>

    <%# #532/#556: bei Status final read-only (gesperrt), sonst editierbar.
        Ein Wrapper mit stabiler id, damit der Status-Wechsel den Bereich
        per Turbo-Stream live umschaltet (siehe update.turbo_stream). %>
    <%= render "documents/editor", document: document %>

    <%= render "printables/artifacts", printable: document %>
  </div>
</article>

<%# #786 (Hans): Bankverbindungs-Editor am Person/Org-KI — analog zum
    Adress-Editor (Chevron + Anzeige/Edit + Add + Lösch-Rückfrage, DB-direkt).
    Mehrere möglich. Locals: item, in_stack %>
<% return unless item.item_type.in?(%w[person organization]) %>
<% accounts = item.bank_accounts.ordered %>
<% collapsed = accounts.empty? %>
<section id="bank_accounts_section_<%= item.uuid %>"
         data-controller="disclosure section-edit rows-editor"
         data-disclosure-storage-key-value="knowledge.<%= item.uuid %>.bank"
         class="border border-slate-200 rounded">
  <header class="px-3 py-1.5 text-xs text-slate-600 border-b border-slate-100 font-medium flex items-center gap-2 bg-slate-50 rounded-t">
    <button type="button" data-action="click->disclosure#toggle"
            class="flex items-center gap-2 flex-1 text-left bg-transparent border-0 p-0 cursor-pointer text-slate-600">
      <span data-disclosure-target="icon" class="inline-block transition-transform <%= 'rotate-90' unless collapsed %> text-slate-400 [&_svg]:w-3.5 [&_svg]:h-3.5"><%= icon "chevron_right" %></span>
      <span><%= t("knowledge.editors.bank.title") %> · <%= accounts.size %></span>
    </button>
    <button type="button" data-action="click->disclosure#expand click->section-edit#edit" title="<%= t("actions.edit") %>"
            class="p-0.5 text-slate-400 hover:text-slate-700 [&_svg]:w-3.5 [&_svg]:h-3.5"><%= icon "pencil" %></button>
    <button type="button" data-action="click->disclosure#expand click->section-edit#edit click->rows-editor#add"
            title="<%= t("knowledge.editors.bank.add") %>" class="p-0.5 text-emerald-600 hover:text-emerald-800 [&_svg]:w-4 [&_svg]:h-4"><%= icon "plus_circle" %></button>
  </header>

  <div data-disclosure-target="content" class="<%= 'hidden' if collapsed %>">
    <%# ── Anzeige ── %>
    <div data-section-edit-target="display" class="px-3 py-2 text-[13px] space-y-1.5">
      <% if accounts.any? %>
        <% accounts.each do |a| %>
          <div class="flex items-start gap-1.5">
            <span class="min-w-0">
              <% if a.label.present? %><span class="text-slate-500"><%= a.label %>:</span> <% end %><span class="tabular-nums"><%= a.iban_pretty %></span><% if a.bic.present? %> <span class="text-[11px] text-slate-400">· BIC <%= a.bic %></span><% end %><% if a.bank_name.present? %> <span class="text-[11px] text-slate-400">· <%= a.bank_name %></span><% end %><% if a.holder.present? %> <span class="text-[11px] text-slate-400">· <%= a.holder %></span><% end %>
            </span>
            <% if a.iban.present? %>
              <button type="button" data-controller="copy-clipboard" data-action="click->copy-clipboard#copy"
                      data-copy-clipboard-content-value="<%= a.iban %>" data-copy-clipboard-toast-value="<%= t("knowledge.editors.bank.copied") %>"
                      title="<%= t("knowledge.editors.bank.copy") %>" aria-label="<%= t("knowledge.editors.bank.copy") %>"
                      class="shrink-0 mt-0.5 p-0.5 rounded text-slate-400 hover:text-slate-700 hover:bg-slate-100 cursor-pointer [&_svg]:w-3.5 [&_svg]:h-3.5"><%= icon "copy" %></button>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <p class="text-slate-400 italic"><%= t("knowledge.editors.bank.empty") %></p>
      <% end %>
    </div>

    <%# ── Edit ── %>
    <div data-section-edit-target="edit" hidden>
      <%= form_with url: bank_accounts_knowledge_item_path(item.uuid), method: :patch, local: false do |f| %>
        <% if in_stack %><%= f.hidden_field :in_stack, value: "1" %><% end %>
        <template data-rows-editor-target="template">
          <div data-row class="px-3 py-1.5 border-b border-slate-50 grid grid-cols-[1fr_auto] gap-2 items-center">
            <div class="space-y-1 min-w-0">
              <input type="text" name="bank_accounts[][iban]" placeholder="<%= t("knowledge.editors.bank.iban_placeholder") %>" class="w-full border border-slate-200 rounded px-1 py-0.5 text-xs font-mono">
              <div class="grid grid-cols-2 gap-1">
                <input type="text" name="bank_accounts[][bic]" placeholder="<%= t("knowledge.editors.bank.bic_placeholder") %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs font-mono">
                <input type="text" name="bank_accounts[][bank_name]" placeholder="<%= t("knowledge.editors.bank.bank_placeholder") %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
              </div>
              <div class="grid grid-cols-2 gap-1">
                <input type="text" name="bank_accounts[][holder]" placeholder="<%= t("knowledge.editors.bank.holder_placeholder") %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
                <input type="text" name="bank_accounts[][label]" placeholder="<%= t("knowledge.editors.bank.label_placeholder") %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
              </div>
            </div>
            <button type="button" data-action="click->rows-editor#removeConfirm" class="p-1 text-slate-400 hover:text-rose-600">×</button>
          </div>
        </template>

        <div data-rows-editor-target="rows">
          <% accounts.each do |a| %>
            <div data-row data-existing="true" class="px-3 py-1.5 border-b border-slate-50 grid grid-cols-[1fr_auto] gap-2 items-center">
              <div class="space-y-1 min-w-0">
                <input type="hidden" name="bank_accounts[][id]" value="<%= a.id %>">
                <input type="text" name="bank_accounts[][iban]" value="<%= a.iban %>" placeholder="<%= t("knowledge.editors.bank.iban_placeholder") %>" class="w-full border border-slate-200 rounded px-1 py-0.5 text-xs font-mono">
                <div class="grid grid-cols-2 gap-1">
                  <input type="text" name="bank_accounts[][bic]" value="<%= a.bic %>" placeholder="<%= t("knowledge.editors.bank.bic_placeholder") %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs font-mono">
                  <input type="text" name="bank_accounts[][bank_name]" value="<%= a.bank_name %>" placeholder="<%= t("knowledge.editors.bank.bank_placeholder") %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
                </div>
                <div class="grid grid-cols-2 gap-1">
                  <input type="text" name="bank_accounts[][holder]" value="<%= a.holder %>" placeholder="<%= t("knowledge.editors.bank.holder_placeholder") %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
                  <input type="text" name="bank_accounts[][label]" value="<%= a.label %>" placeholder="<%= t("knowledge.editors.bank.label_placeholder") %>" class="border border-slate-200 rounded px-1 py-0.5 text-xs">
                </div>
              </div>
              <button type="button" data-action="click->rows-editor#removeConfirm" class="p-1 text-slate-400 hover:text-rose-600">×</button>
            </div>
          <% end %>
        </div>

        <div class="flex items-center gap-2 px-3 py-2 border-t border-slate-100 bg-slate-50/50">
          <button type="button" data-action="click->section-edit#cancel" class="text-xs px-2 py-0.5 rounded text-slate-600 hover:bg-slate-100"><%= t("actions.cancel") %></button>
          <button type="submit" class="ml-auto text-xs px-3 py-0.5 rounded bg-emerald-600 text-white hover:bg-emerald-700 cursor-pointer"><%= t("actions.save") %></button>
        </div>
      <% end %>
    </div>
  </div>
</section>

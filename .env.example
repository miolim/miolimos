# miolimOS — example environment configuration.
# Copy to .env (gitignored) and adjust. All values have sensible defaults;
# nothing here is required to boot, but self-hosters will want to set the
# host and admin credentials.

# ── Host / URLs ──────────────────────────────────────────────────────
# Public hostname used for mailer links, Action Cable origin checks and
# "own host" link detection. Default: os.miolim.de
MIOLIMOS_HOST=your-host.example.com
# Protocol for mailer URLs. Default: https
MIOLIMOS_PROTOCOL=https

# ── Seed admin user (db/seeds.rb) ────────────────────────────────────
# Used only when seeding a fresh database. If MIOLIMOS_ADMIN_PASSWORD is
# unset, a random password is generated and printed once during seeding.
MIOLIMOS_ADMIN_EMAIL=admin@example.com
MIOLIMOS_ADMIN_NAME=Admin
MIOLIMOS_ADMIN_PASSWORD=

# ── Database ─────────────────────────────────────────────────────────
# Password for the production database user (see config/database.yml).
MIOLIMOS_SRC_DATABASE_PASSWORD=
# Host + user for the production database. Defaults: localhost / miolimos_src.
# (docker compose sets MIOLIMOS_DB_HOST=db automatically.)
# MIOLIMOS_DB_HOST=localhost
# MIOLIMOS_DB_USER=miolimos_src

# ── Encryption (REQUIRED in production) ──────────────────────────────
# Lockbox encrypts sensitive fields. Production refuses to boot without a
# key. Generate a 64-char hex key, e.g.:
#   bin/rails runner "puts SecureRandom.hex(32)"
# Alternatively store it in Rails credentials as credentials[:lockbox][:master_key].
LOCKBOX_MASTER_KEY=

# ── Optional integrations ────────────────────────────────────────────
# Inbox AI (transforms, summaries, tag suggestions) via Anthropic. Falls
# back to local Ollama if running; without either, AI inbox steps are
# unavailable. Can also live in credentials[:anthropic][:api_key].
ANTHROPIC_API_KEY=
# Audio/video transcription (Whisper). Without it, transcription is
# unavailable; nothing else breaks. Can also live in credentials[:openai][:api_key].
OPENAI_API_KEY=
# Speaker recognition (diarization) for YouTube transcripts via AssemblyAI.
# Optional: with this key, the inbox offers a "with speaker recognition" path
# that attributes interview/discussion text to individual speakers. Without it,
# only the normal Whisper transcription is offered. Can also live in
# credentials[:assemblyai][:api_key]. Optional: ASSEMBLYAI_USD_PER_MINUTE
# overrides the cost estimate (default 0.0045).
ASSEMBLYAI_API_KEY=
# Gmail send/sync + Google Calendar use OAuth credentials stored in Rails
# credentials (google.oauth_client_id / google.oauth_client_secret).
# See Settings → Accounts in the app for the redirect-URI setup.
# Run the Solid Queue worker inside Puma (set in docker compose):
# SOLID_QUEUE_IN_PUMA=true

# ── Inbox import path (optional) ─────────────────────────────────────
# Where the file-drop importer looks for *.md files.
# Default: $MIOLIMOS_DATA_PATH/inbox
# MIOLIMOS_INBOX_PATH=/path/to/inbox

# ── Customer portal (optional) ───────────────────────────────────────
# Hostname for the customer portal links in portal emails.
# Default: portal.miolim.de
# PORTAL_HOST=portal.your-host.example.com

# ── Document rendering (optional) ────────────────────────────────────
# Chrome/Chromium binary for document PDFs (letters, invoices).
# CHROME_BIN=google-chrome
# Python interpreter (venv with drafthorse + factur-x) for ZUGFeRD/XRechnung
# e-invoice generation. Without it, invoices render as plain PDFs.
# ZUGFERD_PYTHON=~/.venvs/miolimos-zugferd/bin/python

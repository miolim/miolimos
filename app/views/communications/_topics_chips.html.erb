<%# Chips für die Themen einer Communication. Stream-replaced bei add/remove. %>
<div id="comm_topics_chips_<%= comm.id %>" class="flex flex-wrap gap-1.5">
  <% comm.topics.order(:name).each do |topic| %>
    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-slate-100 text-xs">
      <%= topic_dot topic %>
      <%= topic.name %>
      <%= button_to communication_topic_path(comm, topic), method: :delete,
            form: { class: "inline m-0 p-0", data: { turbo_stream: true } },
            title: t("communications.unlink_topic"), "aria-label": t("communications.unlink"),
            class: "ml-0.5 -mr-0.5 p-0 text-slate-400 hover:text-rose-600 bg-transparent border-0 cursor-pointer leading-none" do %>
        ×
      <% end %>
    </span>
  <% end %>
</div>

<%# #613: aus app/views/settings/templates/index.html.erb in den Einstellungs-Stack gezogen (Blade-Inhalt).
    Daten lädt Settings::BladesController#load_templates. %>
  
  <div class="bg-white rounded border border-slate-200">
    <header class="px-4 py-2 border-b border-slate-200 flex items-center gap-3">
      <span class="font-semibold"><%= t("nav.templates") %></span>
      <span class="ml-auto">
        <%= link_to t("settings.topic_templates.new_button"),
              new_topic_path(topic: { template: "1" }),
              class: "text-xs px-2 py-1 rounded bg-emerald-600 text-white hover:bg-emerald-700" %>
      </span>
    </header>

    <% if @topic_templates.empty? %>
      <p class="px-4 py-3 text-slate-500"><%= t("settings.topic_templates.empty") %></p>
    <% else %>
      <ul class="divide-y divide-slate-100 text-[13px]">
        <% @topic_templates.each do |topic| %>
          <li class="px-4 py-2 flex items-center gap-3 hover:bg-slate-50">
            <%= topic_dot topic %>
            <%= link_to topic.name, topic_path(topic),
                  class: "flex-1 text-slate-900 hover:underline" %>
            <span class="font-mono text-xs text-slate-500"><%= topic.slug %></span>
            <span class="text-xs text-slate-400"><%= t("settings.topic_templates.task_count_html", count: topic.tasks.count) %></span>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>

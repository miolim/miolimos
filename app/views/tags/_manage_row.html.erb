<%# #428 Phase 4 (Hans, 2026-05-31): Eine Tag-Verwaltungszeile.
    Links: Filter-Link (oeffnet Items mit dem Tag) mit farbigem Namens-Chip.
    Rechts: Inline-Editor fuer Farbe + Beschreibung, Auto-Submit an
    tags#update (PATCH). Locals: t (Tag-Name), with_icon (Bool). %>
<li data-tag="<%= t %>" class="flex items-center gap-2 px-2 py-1 rounded hover:bg-slate-50">
  <button type="button"
          data-controller="blade-link"
          data-blade-link-kind-value="tag_list"
          data-blade-link-id-value="<%= t %>"
          data-action="click->blade-link#append"
          title="<%= I18n.t("tags.items_with_tag_title", tag: t) %>"
          class="flex items-center gap-2 min-w-0 flex-1 text-left bg-transparent border-0 cursor-pointer">
    <span class="inline-flex items-center justify-center w-4 shrink-0 <%= with_icon ? 'text-slate-500' : 'text-slate-400 text-xs' %>">
      <% if with_icon %><%= tag_icon_html(t, size: "w-4 h-4") %><% else %>#<% end %>
    </span>
    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs truncate <%= tag_color_classes(t) %>"><%= t %></span>
  </button>

  <%= form_with url: tag_update_path(tag: t), method: :patch, local: false,
        data: { turbo_stream: true }, class: "flex items-center gap-1 shrink-0" do |f| %>
    <%= f.select :color,
          options_for_select([[I18n.t("tags.color"), ""]] +
            ApplicationHelper::TAG_PALETTE.reject { |c| c == "slate" }.map { |c| [c, c] },
            tag_meta_map.dig(t, :color) || ""),
          {},
          onchange: "this.form.requestSubmit()",
          title: I18n.t("tags.color"),
          class: "text-xs border border-slate-200 rounded px-1 py-0.5 text-slate-600" %>
    <%= f.text_field :description, value: tag_description(t),
          placeholder: I18n.t("tags.description_placeholder"),
          onchange: "this.form.requestSubmit()",
          class: "text-xs border border-slate-200 rounded px-1 py-0.5 w-32" %>
  <% end %>
</li>

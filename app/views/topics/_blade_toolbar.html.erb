<%# #348 Phase 2 (Hans, 2026-05-24): Topic-Blade-Toolbar — eigene Zeile
    fuer die Action-Icons und den Slug, oberhalb des Topic-Titels.
    Analog tasks/_blade_card. Links: Duplikat-Icon direkt neben dem
    Spine. Rechts: Slug + Edit + Delete. Layout-Klassen entsprechen
    der Task-Card-Toolbar (`-mx-3 -mt-3 px-3 pt-2 pb-2 ...`). %>
<div class="-mx-3 -mt-3 px-3 pt-2 pb-2 bg-white
            border-b border-slate-100 flex items-center gap-2 text-slate-500">
  <button type="button"
          data-action="click->blade-stack#duplicateCard"
          data-target-uuid="list:topic:<%= topic.slug %>"
          title="<%= t("tasks.duplicate_card") %>"
          aria-label="<%= t("tasks.duplicate_card") %>"
          class="p-1 rounded hover:bg-slate-100 hover:text-slate-900 bg-transparent border-0 cursor-pointer shrink-0">
    <%= icon "copy" %>
  </button>

  <div class="ml-auto flex items-center gap-1 shrink-0">
    <%# #360 (Hans, 2026-05-25): Per-Blade-Reload als Default-Icon im
        Toolbar. Holt den Card-Inhalt frisch vom Server. %>
    <button type="button"
            data-action="click->blade-stack#reloadCard"
            title="<%= t("tasks.reload_card") %>"
            aria-label="<%= t("tasks.reload_card") %>"
            class="p-1 rounded hover:bg-slate-100 hover:text-slate-900 cursor-pointer">
      <%= icon "refresh" %>
    </button>
    <%# #627 (Hans): Inbox-Import direkt aus dem Topic — gleiches Formular
        wie der Topbar-Quick-Add, aber der Vorgang (und via ProcessorBase
        auch seine Ergebnisse) hängt automatisch an DIESEM Topic. Native
        details/summary als Popover, kein eigener JS-Controller. Der Slug
        ist aus der Zeile raus (steht in den Eigenschaften, #627). %>
    <details class="relative" data-topic-inbox-import>
      <summary title="<%= t("topics.inbox_import_title") %>" aria-label="<%= t("topics.inbox_import_aria") %>"
               class="list-none p-1 rounded hover:bg-slate-100 hover:text-slate-900 cursor-pointer [&::-webkit-details-marker]:hidden">
        <%= icon "inbox" %>
      </summary>
      <div class="absolute right-0 top-8 w-80 z-30 bg-white border border-slate-200 rounded-lg shadow-xl p-3 text-left">
        <div class="text-xs font-semibold text-slate-700 mb-2"><%= t("topics.inbox_import_label") %> <%= topic.name %></div>
        <%= form_with url: inbox_items_path, method: :post, local: true,
              multipart: true, data: { turbo_frame: "_top" }, class: "space-y-2" do |f| %>
          <%= hidden_field_tag "topic_ids[]", topic.slug %>
          <%# #627 v2 (Hans): Item nach dem Anlegen als Detail-Blade an
              den aktuellen Stack anhängen statt zur Inbox zu springen. %>
          <%= hidden_field_tag :stay_in_stack, "1" %>
          <%= f.url_field :source_url,
                placeholder: t("topics.url_placeholder"), autocomplete: "off",
                class: "w-full rounded border border-slate-200 px-2 py-1 text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" %>
          <%= f.text_area :raw_content,
                placeholder: t("topics.paste_placeholder"), rows: 4,
                class: "w-full rounded border border-slate-200 px-2 py-1 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-slate-400 [field-sizing:content] resize-y" %>
          <label class="flex items-center gap-2 text-xs text-slate-600 cursor-pointer">
            <span class="text-slate-500 [&_svg]:w-4 [&_svg]:h-4"><%= icon "paperclip" %></span>
            <%= f.file_field :file, accept: "application/pdf,image/*,.md,.markdown,text/markdown",
                  class: "text-xs flex-1 min-w-0" %>
          </label>
          <div class="flex justify-end">
            <%= f.submit t("topics.submit_inbox"),
                  class: "text-xs px-3 py-1 rounded bg-slate-700 text-white hover:bg-slate-800 cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </details>
    <%# #571: Portal aus Kundensicht öffnen (nur Projekte). %>
    <% if topic.project? %>
      <%= link_to portal_preview_topic_path(topic), target: "_blank", rel: "noopener",
            data: { turbo: false },
            title: t("topics.portal_open"), "aria-label": t("topics.portal"),
            class: "p-1 rounded hover:bg-slate-100 hover:text-slate-900" do %>
        <%= icon "globe" %>
      <% end %>
    <% end %>
    <%# #567: Eigenschaften als Blade im aktuellen Stack statt Vollnavigation. %>
    <button type="button"
            data-controller="blade-link"
            data-blade-link-kind-value="topic_props"
            data-blade-link-id-value="<%= topic.slug %>"
            data-action="click->blade-link#append"
            title="<%= t("actions.edit") %>" aria-label="<%= t("actions.edit") %>"
            class="p-1 rounded hover:bg-slate-100 hover:text-slate-900 bg-transparent border-0 cursor-pointer">
      <%= icon "pencil" %>
    </button>
    <%= button_to topic_path(topic), method: :delete,
          class: "p-1 rounded hover:bg-rose-50 hover:text-rose-700 bg-transparent border-0 cursor-pointer",
          title: t("actions.delete"), "aria-label": t("actions.delete"),
          form: { class: "inline m-0 p-0", data: { turbo_frame: "_top", turbo_confirm: t("topics.delete_confirm") } } do %>
      <%= icon "trash" %>
    <% end %>
  </div>
</div>

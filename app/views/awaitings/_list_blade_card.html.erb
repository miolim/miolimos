<%# #163 Phase 5a-2: Listen-Blade fuer Wartepunkte. %>
<%
  stack_id = "list:awaitings"
  awaitings = Awaiting.open.includes(:contact_ki).by_urgency.limit(50).to_a
%>
<article id="stack_card_<%= stack_id %>"
         data-uuid="<%= stack_id %>"
         class="stack-card shrink-0 relative w-[26rem] max-w-[calc(100vw-3rem)]
                bg-white border-l border-slate-200 first:border-l-0 flex">

  <aside class="stack-spine self-stretch w-7 shrink-0 bg-slate-50 border-r border-slate-200
                flex flex-col items-center pt-2 gap-2 cursor-pointer hover:bg-slate-100"
         title="<%= t("nav.waiting") %>"
         data-action="click->blade-stack#focusCard dblclick->blade-stack#toggleCollapse"
         data-target-uuid="<%= stack_id %>">
    <span class="shrink-0 text-amber-500"><%= icon "waiting" %></span>
    <span class="text-xs text-slate-700 font-medium whitespace-nowrap overflow-hidden text-ellipsis
                 [writing-mode:vertical-rl] min-h-0 flex-1">
      <%= t("nav.waiting") %>
    </span>
    <%= render "shared/blade_close_button" %>
  </aside>

  <div class="flex-1 min-w-0 min-h-0 overflow-y-auto p-3 space-y-2"
       data-controller="list-search">
    <%# #703 (Hans): einheitlicher Topbereich via shared/list_header. %>
    <%= render "shared/list_header",
          lead_icon: "waiting", title: t("nav.waiting"),
          count: awaitings.size, total: Awaiting.open.count,
          search: render("shared/list_search", placeholder: t("awaitings.list_search_placeholder")) %>

    <% if awaitings.empty? %>
      <p class="text-sm text-slate-400 italic py-3">Keine offenen Wartepunkte.</p>
    <% else %>
      <ul class="divide-y divide-slate-100 text-[13px]">
        <% awaitings.each do |a| %>
          <li class="py-1.5 hover:bg-slate-50 flex items-baseline gap-2">
            <span class="shrink-0 <%= a.overdue? ? 'text-rose-500' : 'text-amber-500' %>" title="Wartepunkt">⏳</span>
            <%# #163 Phase 5b-1: Wartepunkt als Detail-Blade appenden. %>
            <a href="#"
               data-action="click->blade-stack#openAwaiting"
               data-awaiting-id="<%= a.id %>"
               class="flex-1 min-w-0 hover:underline text-slate-700">
              <span class="truncate inline-block max-w-full align-bottom"><%= a.title.truncate(60) %></span>
            </a>
            <% if a.follow_up_at %>
              <span class="text-xs shrink-0 tabular-nums <%= a.overdue? ? 'text-rose-700 font-medium' : 'text-slate-500' %>">
                <%= l(a.follow_up_at, format: :short) %>
              </span>
            <% end %>
          </li>
        <% end %>
      </ul>
      <p data-list-search-target="empty" class="hidden text-xs text-slate-400 italic py-2">Keine Treffer.</p>
    <% end %>
  </div>
</article>
